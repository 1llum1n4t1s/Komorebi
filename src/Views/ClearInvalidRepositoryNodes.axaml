<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Komorebi.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Komorebi.Views.ClearInvalidRepositoryNodes"
             x:DataType="vm:ClearInvalidRepositoryNodes">
  <StackPanel Orientation="Vertical" Margin="8,0,0,0">
    <StackPanel Orientation="Horizontal">
      <Path Width="16" Height="16" Margin="0,0,8,0" Data="{StaticResource Icons.Clear}"/>
      <TextBlock FontSize="18"
                 Classes="bold"
                 Text="{DynamicResource Text.ClearInvalidRepositoryNodes.Title}"/>
    </StackPanel>

    <TextBlock Margin="0,16,8,0"
               TextWrapping="Wrap"
               Foreground="{DynamicResource Brush.FG2}"
               Text="{Binding Message}"/>
  </StackPanel>
</UserControl>
