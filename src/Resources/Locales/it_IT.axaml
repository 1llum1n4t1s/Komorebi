  <x:String x:Key="Text.Error.MissingScanDir" xml:space="preserve">Directory root di scansione mancante!</x:String>
  <x:String x:Key="Text.Error.NoCommitsToAmend" xml:space="preserve">Nessun commit da modificare!</x:String>
  <x:String x:Key="Text.Error.RepoHasUnfinishedJob" xml:space="preserve">Il repository ha un lavoro non completato! Attendere!</x:String>
  <x:String x:Key="Text.Error.RepoHasConflicts" xml:space="preserve">Il repository ha conflitti non risolti. Lo staging automatico e il commit sono disabilitati!</x:String>
  <x:String x:Key="Text.Error.TerminalNotSpecified" xml:space="preserve">Terminale non specificato! Verificare che la shell/terminale corretta sia stata configurata.</x:String>
  <x:String x:Key="Text.Progress.AddingSubmodule" xml:space="preserve">Aggiunta sottomodulo...</x:String>
