  <x:String x:Key="Text.Configure.CommitMessageTemplate.BuiltinVars" xml:space="preserve">अन्तर्निर्मितपरिमितयः:&#xD;&#xD;
&#xD;&#xD;
${branch_name} वर्तमानस्थानीयशाखानाम।&#xD;&#xD;
${files_num} परिवर्तितसञ्चिकासंख्या&#xD;&#xD;
${files} परिवर्तितसञ्चिकामार्गाः&#xD;&#xD;
${files:N} अधिकतमाः N परिवर्तितसञ्चिकामार्गाः&#xD;&#xD;
${pure_files} ${files} सदृशं, किन्तु केवलं सञ्चिकानामानि&#xD;&#xD;
${pure_files:N} ${files:N} सदृशं, किन्तु पत्रिकाभिः विना</x:String>
  <x:String x:Key="Text.Configure.CommitMessageTemplate.Content" xml:space="preserve">प्रारूपविषयः:</x:String>
  <x:String x:Key="Text.Configure.CommitMessageTemplate.Name" xml:space="preserve">प्रारूपनाम:</x:String>
  <x:String x:Key="Text.Configure.CustomAction" xml:space="preserve">अभिरुचिक्रिया</x:String>
  <x:String x:Key="Text.Configure.CustomAction.Arguments" xml:space="preserve">परिमितयः:</x:String>
  <x:String x:Key="Text.Configure.CustomAction.Arguments.Tip" xml:space="preserve">अन्तर्निर्मितपरिमितयः:&#xD;&#xD;
&#xD;&#xD;
${REPO} भण्डारमार्गः&#xD;&#xD;
${REMOTE} चयनितं दूरस्थं वा चयनितशाखायाः दूरस्थम्&#xD;&#xD;
${BRANCH} चयनिता शाखा, दूरस्थशाखानां कृते ${REMOTE} भागं विना&#xD;&#xD;
${BRANCH_FRIENDLY_NAME} चयनितशाखायाः सुबोधनाम, दूरस्थशाखानां कृते ${REMOTE} भागसहितम्&#xD;&#xD;
${SHA} चयनितप्रतिबद्धस्य हैश्&#xD;&#xD;
${TAG} चयनितं चिह्नम्&#xD;&#xD;
${FILE} चयनिता सञ्चिका, भण्डारमूलसापेक्षा&#xD;&#xD;
$1, $2 ... निवेशनियन्त्रणमूल्यानि</x:String>
