  <x:String x:Key="Text.GitFlow.StartFeatureTitle" xml:space="preserve">FLOW - विशेषतां प्रारभतु</x:String>
  <x:String x:Key="Text.GitFlow.StartHotfix" xml:space="preserve">तात्कालिकसंशोधनं प्रारभतु...</x:String>
  <x:String x:Key="Text.GitFlow.StartHotfixTitle" xml:space="preserve">FLOW - तात्कालिकसंशोधनं प्रारभतु</x:String>
  <x:String x:Key="Text.GitFlow.StartPlaceholder" xml:space="preserve">नाम प्रविष्टं कुरुत</x:String>
  <x:String x:Key="Text.GitFlow.StartRelease" xml:space="preserve">प्रकाशनं प्रारभतु...</x:String>
  <x:String x:Key="Text.GitFlow.StartReleaseTitle" xml:space="preserve">FLOW - प्रकाशनं प्रारभतु</x:String>
  <x:String x:Key="Text.GitFlow.TagPrefix" xml:space="preserve">संस्करणचिह्नपूर्वप्रत्ययः:</x:String>
  <x:String x:Key="Text.GitLFS" xml:space="preserve">Git LFS</x:String>
  <x:String x:Key="Text.GitLFS.AddTrackPattern" xml:space="preserve">अनुसरणप्रतिमानं योजयतु...</x:String>
  <x:String x:Key="Text.GitLFS.AddTrackPattern.IsFilename" xml:space="preserve">प्रतिमानं सञ्चिकानाम अस्ति</x:String>
  <x:String x:Key="Text.GitLFS.AddTrackPattern.Pattern" xml:space="preserve">अभिरुचिप्रतिमानम्:</x:String>
  <x:String x:Key="Text.GitLFS.AddTrackPattern.Title" xml:space="preserve">Git LFS मध्ये अनुसरणप्रतिमानं योजयतु</x:String>
  <x:String x:Key="Text.GitLFS.Fetch" xml:space="preserve">आनयतु</x:String>
  <x:String x:Key="Text.GitLFS.Fetch.Tips" xml:space="preserve">Git LFS वस्तूनि अवतारयितुं `git lfs fetch` चालयतु। एतत् कार्यप्रतिम् अद्यतनं न करोति।</x:String>
  <x:String x:Key="Text.GitLFS.Fetch.Title" xml:space="preserve">LFS वस्तूनि आनयतु</x:String>
  <x:String x:Key="Text.GitLFS.Install" xml:space="preserve">Git LFS हुक् संस्थापयतु</x:String>
  <x:String x:Key="Text.GitLFS.Locks" xml:space="preserve">तालान् दर्शयतु</x:String>
  <x:String x:Key="Text.GitLFS.Locks.Empty" xml:space="preserve">तालिताः सञ्चिकाः नास्ति</x:String>
  <x:String x:Key="Text.GitLFS.Locks.Lock" xml:space="preserve">तालयतु</x:String>
  <x:String x:Key="Text.GitLFS.Locks.OnlyMine" xml:space="preserve">केवलं मदीयतालान् दर्शयतु</x:String>
  <x:String x:Key="Text.GitLFS.Locks.Title" xml:space="preserve">LFS तालाः</x:String>
  <x:String x:Key="Text.GitLFS.Locks.Unlock" xml:space="preserve">उद्घाटयतु</x:String>
  <x:String x:Key="Text.GitLFS.Locks.UnlockAllMyLocks" xml:space="preserve">मदीयसर्वतालान् उद्घाटयतु</x:String>
  <x:String x:Key="Text.GitLFS.Locks.UnlockAllMyLocks.Confirm" xml:space="preserve">किं भवान् निश्चितः यत् सर्वाः तालितसञ्चिकाः उद्घाटनीयाः?</x:String>
  <x:String x:Key="Text.GitLFS.Locks.UnlockForce" xml:space="preserve">बलात् उद्घाटयतु</x:String>
  <x:String x:Key="Text.GitLFS.Prune" xml:space="preserve">शोधनम्</x:String>
  <x:String x:Key="Text.GitLFS.Prune.Tips" xml:space="preserve">स्थानीयभण्डारात् पुरातनानि LFS सञ्चिकानि विलोपयितुं `git lfs prune` चालयतु</x:String>
  <x:String x:Key="Text.GitLFS.Pull" xml:space="preserve">आकर्षणम्</x:String>
  <x:String x:Key="Text.GitLFS.Pull.Tips" xml:space="preserve">वर्तमानसन्दर्भस्य सर्वाणि Git LFS सञ्चिकानि अवतारयित्वा निष्कासयितुं `git lfs pull` चालयतु</x:String>
  <x:String x:Key="Text.GitLFS.Pull.Title" xml:space="preserve">LFS वस्तूनि आकर्षयतु</x:String>
  <x:String x:Key="Text.GitLFS.Push" xml:space="preserve">प्रेषणम्</x:String>
  <x:String x:Key="Text.GitLFS.Push.Tips" xml:space="preserve">पङ्क्तिस्थानि बृहत्सञ्चिकानि Git LFS अन्तबिन्दुं प्रति प्रेषयतु</x:String>
  <x:String x:Key="Text.GitLFS.Push.Title" xml:space="preserve">LFS वस्तूनि प्रेषयतु</x:String>
  <x:String x:Key="Text.GitLFS.Remote" xml:space="preserve">दूरस्थम्:</x:String>
  <x:String x:Key="Text.GitLFS.Track" xml:space="preserve">'{0}' नामसञ्चिकाः अनुसरतु</x:String>
  <x:String x:Key="Text.GitLFS.TrackByExtension" xml:space="preserve">सर्वाः *{0} सञ्चिकाः अनुसरतु</x:String>
