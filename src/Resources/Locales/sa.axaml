  <x:String x:Key="Text.AddWorktree.Tracking.Toggle" xml:space="preserve">दूरस्थशाखायाः अनुसरणम्</x:String>
  <x:String x:Key="Text.AddWorktree.WhatToCheckout" xml:space="preserve">किं निष्कासनीयम्:</x:String>
