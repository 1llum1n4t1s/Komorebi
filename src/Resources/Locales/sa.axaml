  <x:String x:Key="Text.Checkout" xml:space="preserve">शाखां निष्कासयतु</x:String>
  <x:String x:Key="Text.Checkout.Commit" xml:space="preserve">प्रतिबद्धं निष्कासयतु</x:String>
  <x:String x:Key="Text.Checkout.Commit.Target" xml:space="preserve">प्रतिबद्धम्:</x:String>
  <x:String x:Key="Text.Checkout.Commit.Warning" xml:space="preserve">चेतावनी: प्रतिबद्धनिष्कासनेन भवतः शीर्षं विच्छिन्नं भविष्यति</x:String>
  <x:String x:Key="Text.Checkout.LocalChanges" xml:space="preserve">स्थानीयपरिवर्तनानि:</x:String>
  <x:String x:Key="Text.Checkout.LocalChanges.Discard" xml:space="preserve">त्यजतु</x:String>
  <x:String x:Key="Text.Checkout.LocalChanges.StashAndReapply" xml:space="preserve">निक्षिप्य पुनःप्रयोजयतु</x:String>
  <x:String x:Key="Text.Checkout.Target" xml:space="preserve">शाखा:</x:String>
  <x:String x:Key="Text.Checkout.WarnLostCommits" xml:space="preserve">भवतः वर्तमानशीर्षे कस्यापि शाखायाः/चिह्नस्य अयुक्तानि प्रतिबद्धानि सन्ति! किं भवान् अग्रे गन्तुम् इच्छति?</x:String>
  <x:String x:Key="Text.Checkout.WarnUpdatingSubmodules" xml:space="preserve">एतेषाम् उपमॉड्यूलानाम् अद्यतनम् आवश्यकम्:{0}किं भवान् तान् अद्यतनयितुम् इच्छति?</x:String>
  <x:String x:Key="Text.Checkout.WithFastForward" xml:space="preserve">निष्कासनं तथा द्रुतप्रसारणम्</x:String>
  <x:String x:Key="Text.Checkout.WithFastForward.Upstream" xml:space="preserve">द्रुतप्रसारणं प्रति:</x:String>
  <x:String x:Key="Text.CherryPick" xml:space="preserve">चयनोद्धरणम्</x:String>
  <x:String x:Key="Text.CherryPick.AppendSourceToMessage" xml:space="preserve">स्रोतं प्रतिबद्धसन्देशे योजयतु</x:String>
  <x:String x:Key="Text.CherryPick.Commit" xml:space="preserve">प्रतिबद्धम्(प्रतिबद्धानि):</x:String>
  <x:String x:Key="Text.CherryPick.CommitChanges" xml:space="preserve">सर्वपरिवर्तनानि प्रतिबध्नातु</x:String>
  <x:String x:Key="Text.CherryPick.Mainline" xml:space="preserve">मुख्यरेखा:</x:String>
  <x:String x:Key="Text.CherryPick.Mainline.Tips" xml:space="preserve">सामान्यतः विलयनस्य चयनोद्धरणं कर्तुं न शक्यते यतः विलयनस्य कः पक्षः मुख्यरेखा इति ज्ञातुं न शक्यते। एषः विकल्पः निर्दिष्टजनकं सापेक्षं परिवर्तनं पुनःप्रदर्शयितुं शक्नोति।</x:String>
  <x:String x:Key="Text.ClearStashes" xml:space="preserve">निक्षेपान् मार्जयतु</x:String>
  <x:String x:Key="Text.ClearStashes.Message" xml:space="preserve">भवान् सर्वान् निक्षेपान् मार्जयितुम् उद्यतः। किं भवान् निश्चितः?</x:String>
  <x:String x:Key="Text.Clone" xml:space="preserve">दूरस्थभण्डारं प्रतिरूपयतु</x:String>
  <x:String x:Key="Text.Clone.AdditionalParam" xml:space="preserve">अतिरिक्तपरिमितयः:</x:String>
  <x:String x:Key="Text.Clone.AdditionalParam.Placeholder" xml:space="preserve">प्रतिरूपणार्थम् अतिरिक्तपरिमितयः। ऐच्छिकम्।</x:String>
  <x:String x:Key="Text.Clone.LocalName" xml:space="preserve">स्थानीयनाम:</x:String>
  <x:String x:Key="Text.Clone.LocalName.Placeholder" xml:space="preserve">भण्डारनाम। ऐच्छिकम्।</x:String>
  <x:String x:Key="Text.Clone.ParentFolder" xml:space="preserve">जनकपत्रिका:</x:String>
  <x:String x:Key="Text.Clone.RecurseSubmodules" xml:space="preserve">उपमॉड्यूलानि आरम्भयतु तथा अद्यतनयतु</x:String>
  <x:String x:Key="Text.Clone.RemoteURL" xml:space="preserve">भण्डार-URL:</x:String>
  <x:String x:Key="Text.Close" xml:space="preserve">पिदधातु</x:String>
