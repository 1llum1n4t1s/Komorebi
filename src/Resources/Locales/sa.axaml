  <x:String x:Key="Text.Askpass" xml:space="preserve">Komorebi कूटशब्दप्रश्नः</x:String>
  <x:String x:Key="Text.Askpass.Hint.HostKeyChanged" xml:space="preserve">दूरस्थसेवकस्य SSH-कुञ्चिका अन्तिमसंयोजनात् परिवर्तिता अस्ति। सेवकः पुनः स्थापितः स्यात् अथवा तस्य कुञ्चिका नवीकृता स्यात्। प्रशासकेन सह पुष्टिं कुरुत अग्रे गन्तुम्।</x:String>
  <x:String x:Key="Text.Askpass.Hint.HostKeyNew" xml:space="preserve">अयम् अस्य सेवकस्य प्रथमः सम्बन्धः। अङ्गुलिचिह्नं सम्यक् अस्ति इति सुनिश्चित्य OK इति क्लिक् कुरुत ज्ञातसेवकेषु योजयितुम्।</x:String>
  <x:String x:Key="Text.Askpass.Hint.Passphrase" xml:space="preserve">प्रमाणीकरणार्थं स्वस्य SSH-गोपनीयकुञ्चिकायाः कूटशब्दं प्रविशतु।</x:String>
  <x:String x:Key="Text.Askpass.Hint.Password" xml:space="preserve">प्रमाणीकरणार्थं दूरस्थभण्डारस्य कूटशब्दं प्रविशतु।</x:String>
  <x:String x:Key="Text.Askpass.Passphrase" xml:space="preserve">कूटवाक्यं प्रविष्टं कुरुत:</x:String>
  <x:String x:Key="Text.AssumeUnchanged" xml:space="preserve">अपरिवर्तितमिति गृहीताः सञ्चिकाः</x:String>
  <x:String x:Key="Text.AssumeUnchanged.Empty" xml:space="preserve">अपरिवर्तितमिति गृहीताः सञ्चिकाः नास्ति</x:String>
  <x:String x:Key="Text.Avatar.Load" xml:space="preserve">चित्रं लोडयतु...</x:String>
  <x:String x:Key="Text.Avatar.Refetch" xml:space="preserve">पुनः आनयतु</x:String>
  <x:String x:Key="Text.BinaryNotSupported" xml:space="preserve">द्विचरसञ्चिका असमर्थिता!!!</x:String>
  <x:String x:Key="Text.Bisect">द्विभाजनम्</x:String>
  <x:String x:Key="Text.Bisect.Abort">परित्यजतु</x:String>
  <x:String x:Key="Text.Bisect.Bad">दुष्टम्</x:String>
  <x:String x:Key="Text.Bisect.Detecting">द्विभाजनं प्रवर्तते। वर्तमानं HEAD सुष्ठु वा दुष्टं वा?</x:String>
  <x:String x:Key="Text.Bisect.Good">सुष्ठु</x:String>
  <x:String x:Key="Text.Bisect.Skip">लङ्घयतु</x:String>
  <x:String x:Key="Text.Bisect.WaitingForRange">द्विभाजनं प्रवर्तते। वर्तमानप्रतिबद्धं सुष्ठु वा दुष्टं वा इति चिह्नयतु अन्यच्च निष्कासयतु।</x:String>
  <x:String x:Key="Text.Blame" xml:space="preserve">दोषारोपणम्</x:String>
  <x:String x:Key="Text.Blame.BlameOnPreviousRevision" xml:space="preserve">पूर्वसंशोधने दोषारोपणम्</x:String>
  <x:String x:Key="Text.Blame.IgnoreWhitespace">रिक्तस्थानपरिवर्तनानि उपेक्षन्ताम्</x:String>
  <x:String x:Key="Text.Blame.TypeNotSupported" xml:space="preserve">अस्यां सञ्चिकायां दोषारोपणम् असमर्थितम्!!!</x:String>
