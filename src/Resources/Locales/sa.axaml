  <x:String x:Key="Text.Error.RepoHasUnfinishedJob" xml:space="preserve">भण्डारे अपूर्णं कार्यम् अस्ति! कृपया प्रतीक्षताम्!</x:String>
  <x:String x:Key="Text.Error.RepoHasConflicts" xml:space="preserve">भण्डारे असमाधिताः विरोधाः सन्ति। स्वचालित-stage तथा commit निष्क्रियाः!</x:String>
  <x:String x:Key="Text.Error.TerminalNotSpecified" xml:space="preserve">Terminal निर्दिष्टं नास्ति! कृपया सम्यक् shell/terminal विन्यस्तम् इति सुनिश्चितं कुरुत।</x:String>
  <x:String x:Key="Text.Progress.AddingSubmodule" xml:space="preserve">उपघटकं योजयति...</x:String>
  <x:String x:Key="Text.Progress.AddingWorktree" xml:space="preserve">Worktree योजयति...</x:String>
  <x:String x:Key="Text.Progress.Archiving" xml:space="preserve">सङ्ग्रहयति...</x:String>
  <x:String x:Key="Text.Progress.ApplyPatch" xml:space="preserve">Patch प्रयुनक्ति...</x:String>
  <x:String x:Key="Text.Progress.AddingRemote" xml:space="preserve">Remote योजयति...</x:String>
  <x:String x:Key="Text.Progress.AddingIgnoredFiles" xml:space="preserve">उपेक्षितसञ्चिकाः योजयति...</x:String>
  <x:String x:Key="Text.Progress.CheckoutAndFastForward" xml:space="preserve">Checkout तथा Fast-Forward '{0}'...</x:String>
  <x:String x:Key="Text.Progress.WaitingBranchUpdate" xml:space="preserve">Branch नवीकरणं प्रतीक्षते...</x:String>
  <x:String x:Key="Text.Progress.CheckoutCommit" xml:space="preserve">Commit '{0}' checkout करोति...</x:String>
  <x:String x:Key="Text.Progress.ApplyingStash" xml:space="preserve">Stash प्रयुनक्ति: {0}</x:String>
  <x:String x:Key="Text.Progress.Checkout" xml:space="preserve">Checkout '{0}'...</x:String>
  <x:String x:Key="Text.Progress.Cleanup" xml:space="preserve">शोधनम् (GC aggressive &amp; prune)...</x:String>
  <x:String x:Key="Text.Progress.CherryPick" xml:space="preserve">Cherry-Pick commit(s)...</x:String>
  <x:String x:Key="Text.Progress.ChangeSubmoduleUrl" xml:space="preserve">उपघटकस्य URL परिवर्तयति...</x:String>
  <x:String x:Key="Text.Progress.ClearIndexCache" xml:space="preserve">सूचिका-cache शोधयति...</x:String>
  <x:String x:Key="Text.Progress.ClearAllStashes" xml:space="preserve">सर्वान् stash अपनयति...</x:String>
  <x:String x:Key="Text.Progress.Cloning" xml:space="preserve">प्रतिलिपिं करोति...</x:String>
  <x:String x:Key="Text.Progress.CreateTag" xml:space="preserve">Tag सृजति...</x:String>
  <x:String x:Key="Text.Progress.DeinitSubmodule" xml:space="preserve">उपघटकं निष्प्रारम्भयति</x:String>
  <x:String x:Key="Text.Progress.DeletingBranch" xml:space="preserve">Branch अपनयति...</x:String>
  <x:String x:Key="Text.Progress.DeletingMultipleTags" xml:space="preserve">बहून् tags अपनयति...</x:String>
  <x:String x:Key="Text.Progress.DeletingMultipleBranches" xml:space="preserve">बहून् branches अपनयति...</x:String>
  <x:String x:Key="Text.Progress.DeletingRemote" xml:space="preserve">Remote अपनयति...</x:String>
  <x:String x:Key="Text.Progress.DeletingSubmodule" xml:space="preserve">उपघटकम् अपनयति...</x:String>
  <x:String x:Key="Text.Progress.DeletingTag" xml:space="preserve">Tag '{0}' अपनयति...</x:String>
  <x:String x:Key="Text.Progress.DropHead" xml:space="preserve">HEAD '{0}' त्यजति...</x:String>
  <x:String x:Key="Text.Progress.DroppingStash" xml:space="preserve">Stash त्यजति: {0}</x:String>
  <x:String x:Key="Text.Progress.EditingRemote" xml:space="preserve">Remote '{0}' सम्पादयति...</x:String>
  <x:String x:Key="Text.Progress.RunCustomAction" xml:space="preserve">स्वकीयक्रियां चालयति...</x:String>
  <x:String x:Key="Text.Progress.FastForward" xml:space="preserve">Fast-Forward...</x:String>
  <x:String x:Key="Text.Progress.GitFlowFinish" xml:space="preserve">Git Flow - {0} समापयति...</x:String>
  <x:String x:Key="Text.Progress.GitFlowStart" xml:space="preserve">Git Flow - {0} प्रारभते...</x:String>
  <x:String x:Key="Text.Progress.InitRepo" xml:space="preserve">Git भण्डारं प्रारभते: '{0}'</x:String>
  <x:String x:Key="Text.Progress.InitGitFlow" xml:space="preserve">Git-flow प्रारभते...</x:String>
  <x:String x:Key="Text.Progress.LFSFetch" xml:space="preserve">Remote तः LFS वस्तूनि आनयति...</x:String>
  <x:String x:Key="Text.Progress.LFSPrune" xml:space="preserve">LFS prune...</x:String>
  <x:String x:Key="Text.Progress.LFSPull" xml:space="preserve">Remote तः LFS वस्तूनि आकर्षति...</x:String>
  <x:String x:Key="Text.Progress.LFSPush" xml:space="preserve">LFS वस्तूनि remote प्रति प्रेषयति...</x:String>
  <x:String x:Key="Text.Progress.LFSTrack" xml:space="preserve">स्वकीयं LFS अनुसरणप्रतिरूपं योजयति...</x:String>
  <x:String x:Key="Text.Progress.Merging" xml:space="preserve">'{0}' मध्ये '{1}' संयोजयति...</x:String>
  <x:String x:Key="Text.Progress.MergeHeads" xml:space="preserve">Head(s) संयोजयति...</x:String>
  <x:String x:Key="Text.Progress.MovingSubmodule" xml:space="preserve">उपघटकं स्थानान्तरयति...</x:String>
  <x:String x:Key="Text.Progress.PruneWorktrees" xml:space="preserve">Worktrees शोधयति...</x:String>
  <x:String x:Key="Text.Progress.PushRevision" xml:space="preserve">Push {0} -&gt; {1}...</x:String>
  <x:String x:Key="Text.Progress.Rebasing" xml:space="preserve">Rebase...</x:String>
  <x:String x:Key="Text.Progress.RemoveWorktree" xml:space="preserve">Worktree अपनयति...</x:String>
  <x:String x:Key="Text.Progress.PruneRemote" xml:space="preserve">Remote मध्ये prune चालयति...</x:String>
  <x:String x:Key="Text.Progress.Pushing" xml:space="preserve">Push {0} -&gt; {1}/{2}...</x:String>
  <x:String x:Key="Text.Progress.PushingTag" xml:space="preserve">Tag प्रेषयति...</x:String>
  <x:String x:Key="Text.Progress.RenamingBranch" xml:space="preserve">'{0}' पुनर्नामकरोति</x:String>
  <x:String x:Key="Text.Progress.Resetting" xml:space="preserve">वर्तमानं branch {0} प्रति पुनःस्थापयति...</x:String>
  <x:String x:Key="Text.Progress.ResettingWithoutCheckout" xml:space="preserve">{0} प्रति {1} पुनःस्थापयति...</x:String>
  <x:String x:Key="Text.Progress.Reverting" xml:space="preserve">Commit '{0}' प्रत्यावर्तयति...</x:String>
  <x:String x:Key="Text.Progress.EditingHeadMessage" xml:space="preserve">HEAD सन्देशं सम्पादयति...</x:String>
  <x:String x:Key="Text.Progress.ScanningRepositories" xml:space="preserve">'{0}' अधः भण्डाराणि अन्विष्यति...</x:String>
  <x:String x:Key="Text.Progress.SetSubmoduleBranch" xml:space="preserve">उपघटकस्य branch स्थापयति...</x:String>
  <x:String x:Key="Text.Progress.SettingUpstream" xml:space="preserve">Upstream स्थापयति...</x:String>
  <x:String x:Key="Text.Progress.StashingChanges" xml:space="preserve">परिवर्तनानि संगृह्णाति...</x:String>
  <x:String x:Key="Text.GitError.IndexLock" xml:space="preserve">अन्यः git प्रक्रिया चलति स्यात्। यदि न, .git निर्देशिकायां .lock सञ्चिकां विलोपयतु।</x:String>
  <x:String x:Key="Text.GitError.MergeConflict" xml:space="preserve">विलयनसङ्घर्षाः अवगताः। प्रत्येकसञ्चिकायां सङ्घर्षान् समाधत्त, ततः स्थापयत कमिट् च कुरुत।</x:String>
  <x:String x:Key="Text.GitError.DetachedHead" xml:space="preserve">HEAD विच्छिन्नम् अस्ति। परिवर्तनानि रक्षितुं नवीनं शाखां रचयतु।</x:String>
  <x:String x:Key="Text.GitError.PushRejected" xml:space="preserve">प्रेषणं प्रत्याख्यातम् यतो दूरस्थे नवीनतराणि परिवर्तनानि सन्ति। प्रथमं आकर्षयतु, ततः पुनः प्रेषयतु।</x:String>
  <x:String x:Key="Text.GitError.UncommittedChanges" xml:space="preserve">अप्रतिबद्धानि परिवर्तनानि सन्ति। अग्रे गन्तुं प्रतिबध्नातु अथवा स्टैश् कुरुत।</x:String>
  <x:String x:Key="Text.GitError.AuthFailed" xml:space="preserve">प्रमाणीकरणं विफलम्। प्रमाणपत्राणि, SSH कुञ्चिकां, अथवा व्यक्तिगतप्रवेशचिह्नं परीक्षयतु।</x:String>
  <x:String x:Key="Text.GitError.RemoteNotFound" xml:space="preserve">दूरस्थं भण्डारं न प्राप्तम्। URL जालसम्बन्धं च परीक्षयतु।</x:String>
  <x:String x:Key="Text.GitError.AlreadyExists" xml:space="preserve">तेन नाम्ना शाखा अथवा चिह्नं पूर्वमेव विद्यते। भिन्नं नाम चिनुत।</x:String>
  <x:String x:Key="Text.GitError.UntrackedOverwritten" xml:space="preserve">अननुसृतानि सञ्चिकानि अधिलेखितानि भविष्यन्ति। तानि चालयतु विलोपयतु वा, अथवा स्टैश् उपयुज्यताम्।</x:String>
  <x:String x:Key="Text.GitError.NetworkError" xml:space="preserve">जालसम्बन्धः विफलः। अन्तर्जालसम्बन्धं प्रतिनिधिसंस्थापनं च परीक्षयतु।</x:String>
  <x:String x:Key="Text.GitError.RebaseInProgress" xml:space="preserve">रिबेस् प्रचलति। प्रथमं वर्तमानं रिबेस् अनुवर्तयतु, अतिक्रामतु, अथवा निवर्तयतु।</x:String>
  <x:String x:Key="Text.GitError.NothingToCommit" xml:space="preserve">प्रतिबद्धुं स्थापितानि परिवर्तनानि नास्ति। प्रथमं सञ्चिकाः स्थापयतु।</x:String>
  <x:String x:Key="Text.GitError.SubmoduleError" xml:space="preserve">उपमॉड्यूल् समस्या अवगता। 'git submodule update --init --recursive' चालयितुं प्रयतताम्।</x:String>
  <x:String x:Key="Text.GitError.LfsError" xml:space="preserve">Git LFS स्थापितं नास्ति अथवा संस्थापितं नास्ति। Git LFS स्थापयतु 'git lfs install' च चालयतु।</x:String>
  <x:String x:Key="Text.GitError.FileTooLarge" xml:space="preserve">सञ्चिका आकारसीमाम् अतिक्रामति। वृहत्सञ्चिकानां अनुसरणाय Git LFS उपयुज्यताम्।</x:String>
  <x:String x:Key="Text.GitError.CherryPickConflict" xml:space="preserve">चेरी-पिक् सङ्घर्षान् उत्पादितवान्। सङ्घर्षान् समाधत्त, ततः 'git cherry-pick --continue' अथवा '--abort' चालयतु।</x:String>
  <x:String x:Key="Text.GitError.MergeNotFinished" xml:space="preserve">पूर्वं विलयनं न समाप्तम्। 'git merge --abort' चालयतु निवर्तयितुं, अथवा समाधय प्रतिबध्नातु।</x:String>
  <x:String x:Key="Text.GitError.NoUpstream" xml:space="preserve">ऊर्ध्वप्रवाहशाखा न स्थापिता। 'git push -u origin &lt;शाखा&gt;' अनुसरणस्थापनाय उपयुज्यताम्।</x:String>
  <x:String x:Key="Text.GitError.ShallowClone" xml:space="preserve">इदं उत्तानं प्रतिरूपं सीमितेतिहासेन। 'git fetch --unshallow' पूर्णेतिहासाय चालयतु।</x:String>
  <x:String x:Key="Text.GitError.DiskFull" xml:space="preserve">बिम्बे पर्याप्तं स्थानं नास्ति। स्थानं मोचयतु पुनः प्रयतताम् च।</x:String>
  <x:String x:Key="Text.GitError.PermissionDenied" xml:space="preserve">सञ्चिकातन्त्रस्य अनुज्ञा प्रत्याख्याता। सञ्चिका-निर्देशिका-अनुज्ञाः परीक्षयतु अथवा उचितैः अधिकारैः चालयतु।</x:String>
  <x:String x:Key="Text.GitError.InvalidRef" xml:space="preserve">अमान्यं सन्दर्भनाम अथवा संशोधनम्। शाखा-चिह्न-प्रतिबद्धिनाम्नि लेखनदोषान् परीक्षयतु।</x:String>
  <x:String x:Key="Text.GitError.RemoteRefNotFound" xml:space="preserve">दूरस्थशाखा अथवा सन्दर्भः न प्राप्तः। विलोपितः स्यात्। 'git fetch --prune' नवीकरणाय चालयतु।</x:String>
  <x:String x:Key="Text.GitError.CorruptObject" xml:space="preserve">भण्डारे भग्नानि अथवा लुप्तानि वस्तूनि सन्ति। 'git fsck' निदानाय प्रयतताम्, अथवा आवश्यकतायां पुनः प्रतिरूपयतु।</x:String>
  <x:String x:Key="Text.GitError.NotARepo" xml:space="preserve">इदं निर्देशिकं git भण्डारं नास्ति। 'git init' रचनाय चालयतु, अथवा मार्गं परीक्षयतु।</x:String>
  <x:String x:Key="Text.GitError.StashError" xml:space="preserve">स्टैश् प्रविष्टयः न प्राप्ताः। प्रयोजयितुं रक्षिताः परिवर्तनाः नास्ति।</x:String>
  <x:String x:Key="Text.GitError.FilterError" xml:space="preserve">clean/smudge शोधकं विफलम्। .gitattributes शोधकसंस्थापनं च परीक्षयतु।</x:String>
  <x:String x:Key="Text.GitError.HookFailed" xml:space="preserve">git अङ्कुशः कार्यं प्रत्याख्यातवान्। अङ्कुशलिपिं परीक्षयतु अथवा '--no-verify' अतिक्रमणाय उपयुज्यताम् (सावधानतया)।</x:String>
  <x:String x:Key="Text.GitError.PatchFailed" xml:space="preserve">सर्तुरा शुद्धतया प्रयोजयितुं न शक्यते। लक्ष्यसञ्चिकाः परिवर्तिताः स्युः। हस्तेन समाधातुं प्रयतताम्।</x:String>
  <x:String x:Key="Text.GitError.HostKeyChanged" xml:space="preserve">दूरस्थसेवकस्य SSH-कुञ्चिका अन्तिमसंयोजनात् परिवर्तिता अस्ति। सेवकः पुनः स्थापितः स्यात् अथवा तस्य कुञ्चिका नवीकृता स्यात्। ~/.ssh/known_hosts इत्यस्मात् पुरातनां कुञ्चिकां निराकुरुत पुनः प्रयतताम्।</x:String>
  <x:String x:Key="Text.GitError.HostKeyVerifyFailed" xml:space="preserve">SSH-सेवककुञ्चिकायाः सत्यापनं विफलम्। सेवकः ~/.ssh/known_hosts सञ्चिकायां पञ्जीकृतः न स्यात्। टर्मिनल-माध्यमेन प्रथमं संयोजयतु सेवककुञ्चिकां योजयितुम्, अथवा SSH-विन्यासं परीक्षतु।</x:String>
  <x:String x:Key="Text.GitError.WorktreeError" xml:space="preserve">कार्यवृक्षसङ्घर्षः: शाखा अन्यत्र पूर्वमेव निष्कासिता स्यात्। 'git worktree list' इत्यनेन परीक्षयतु।</x:String>
</ResourceDictionary>
