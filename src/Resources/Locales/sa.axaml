  <x:String x:Key="Text.InProgress.Rebase" xml:space="preserve">पुनःस्थापनं प्रचलति।</x:String>
  <x:String x:Key="Text.InProgress.Rebase.StoppedAt" xml:space="preserve">अत्र स्थगितम्</x:String>
  <x:String x:Key="Text.InProgress.Revert" xml:space="preserve">प्रत्यावर्तनं प्रचलति।</x:String>
  <x:String x:Key="Text.InProgress.Revert.Head" xml:space="preserve">प्रतिबद्धं प्रत्यावर्त्यते</x:String>
