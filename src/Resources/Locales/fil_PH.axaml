  <x:String x:Key="Text.Error.CanNotFindBranch" xml:space="preserve">Hindi mahanap ang kasalukuyang branch!</x:String>
  <x:String x:Key="Text.Error.NoBranchBeforeFirstCommit" xml:space="preserve">Hindi makagawa ang Git ng branch bago ang iyong unang commit.</x:String>
  <x:String x:Key="Text.Error.MissingScanDir" xml:space="preserve">Walang root directory para sa pag-scan!</x:String>
  <x:String x:Key="Text.Error.NoCommitsToAmend" xml:space="preserve">Walang mga commit na maaaring baguhin!</x:String>
  <x:String x:Key="Text.Error.RepoHasUnfinishedJob" xml:space="preserve">May hindi pa natapos na trabaho ang repository! Mangyaring maghintay!</x:String>
  <x:String x:Key="Text.Error.RepoHasConflicts" xml:space="preserve">May hindi pa nalulutas na mga conflict ang repository. Naka-disable ang auto-stage at commit!</x:String>
  <x:String x:Key="Text.Error.TerminalNotSpecified" xml:space="preserve">Hindi tinukoy ang terminal! Mangyaring tiyakin na naka-configure ang tamang shell/terminal.</x:String>
  <x:String x:Key="Text.Progress.AddingSubmodule" xml:space="preserve">Nagdadagdag ng submodule...</x:String>
  <x:String x:Key="Text.Progress.AddingWorktree" xml:space="preserve">Nagdadagdag ng worktree...</x:String>
  <x:String x:Key="Text.Progress.Archiving" xml:space="preserve">Nag-a-archive...</x:String>
  <x:String x:Key="Text.Progress.ApplyPatch" xml:space="preserve">Nag-a-apply ng patch...</x:String>
  <x:String x:Key="Text.Progress.AddingRemote" xml:space="preserve">Nagdadagdag ng remote...</x:String>
  <x:String x:Key="Text.Progress.AddingIgnoredFiles" xml:space="preserve">Nagdadagdag ng mga ignored file...</x:String>
  <x:String x:Key="Text.Progress.CheckoutAndFastForward" xml:space="preserve">Checkout at Fast-Forward '{0}'...</x:String>
  <x:String x:Key="Text.Progress.WaitingBranchUpdate" xml:space="preserve">Naghihintay ng branch update...</x:String>
  <x:String x:Key="Text.Progress.CheckoutCommit" xml:space="preserve">Checkout ng commit '{0}'...</x:String>
  <x:String x:Key="Text.Progress.ApplyingStash" xml:space="preserve">Nag-a-apply ng stash: {0}</x:String>
  <x:String x:Key="Text.Progress.Checkout" xml:space="preserve">Checkout '{0}'...</x:String>
  <x:String x:Key="Text.Progress.Cleanup" xml:space="preserve">Paglilinis (GC aggressive &amp; prune)...</x:String>
  <x:String x:Key="Text.Progress.CherryPick" xml:space="preserve">Cherry-Pick ng commit(s)...</x:String>
  <x:String x:Key="Text.Progress.ChangeSubmoduleUrl" xml:space="preserve">Binabago ang URL ng submodule...</x:String>
  <x:String x:Key="Text.Progress.ClearIndexCache" xml:space="preserve">Nililinis ang index cache...</x:String>
  <x:String x:Key="Text.Progress.ClearAllStashes" xml:space="preserve">Binubura ang lahat ng stash...</x:String>
  <x:String x:Key="Text.Progress.Cloning" xml:space="preserve">Nagko-clone...</x:String>
  <x:String x:Key="Text.Progress.CreateTag" xml:space="preserve">Gumagawa ng tag...</x:String>
  <x:String x:Key="Text.Progress.DeinitSubmodule" xml:space="preserve">Dine-deinitialize ang submodule</x:String>
  <x:String x:Key="Text.Progress.DeletingBranch" xml:space="preserve">Binubura ang branch...</x:String>
  <x:String x:Key="Text.Progress.DeletingMultipleTags" xml:space="preserve">Binubura ang maraming tag...</x:String>
  <x:String x:Key="Text.Progress.DeletingMultipleBranches" xml:space="preserve">Binubura ang maraming branch...</x:String>
  <x:String x:Key="Text.Progress.DeletingRemote" xml:space="preserve">Binubura ang remote...</x:String>
  <x:String x:Key="Text.Progress.DeletingSubmodule" xml:space="preserve">Binubura ang submodule...</x:String>
  <x:String x:Key="Text.Progress.DeletingTag" xml:space="preserve">Binubura ang tag '{0}'...</x:String>
  <x:String x:Key="Text.Progress.DropHead" xml:space="preserve">Dini-drop ang HEAD '{0}'...</x:String>
  <x:String x:Key="Text.Progress.DroppingStash" xml:space="preserve">Dini-drop ang stash: {0}</x:String>
  <x:String x:Key="Text.Progress.EditingRemote" xml:space="preserve">Ine-edit ang remote '{0}'...</x:String>
  <x:String x:Key="Text.Progress.RunCustomAction" xml:space="preserve">Pinapatakbo ang custom action...</x:String>
  <x:String x:Key="Text.Progress.FastForward" xml:space="preserve">Fast-Forward...</x:String>
  <x:String x:Key="Text.Progress.GitFlowFinish" xml:space="preserve">Git Flow - Tinapos ang {0}...</x:String>
  <x:String x:Key="Text.Progress.GitFlowStart" xml:space="preserve">Git Flow - Sinisimulan ang {0}...</x:String>
  <x:String x:Key="Text.Progress.InitRepo" xml:space="preserve">Ini-initialize ang Git repository sa: '{0}'</x:String>
  <x:String x:Key="Text.Progress.InitGitFlow" xml:space="preserve">Ini-initialize ang git-flow...</x:String>
  <x:String x:Key="Text.Progress.LFSFetch" xml:space="preserve">Kinukuha ang mga LFS object mula sa remote...</x:String>
  <x:String x:Key="Text.Progress.LFSPrune" xml:space="preserve">LFS prune...</x:String>
  <x:String x:Key="Text.Progress.LFSPull" xml:space="preserve">Dina-download ang mga LFS object mula sa remote...</x:String>
  <x:String x:Key="Text.Progress.LFSPush" xml:space="preserve">Ipinapadala ang mga LFS object sa remote...</x:String>
  <x:String x:Key="Text.Progress.LFSTrack" xml:space="preserve">Nagdadagdag ng custom LFS tracking pattern...</x:String>
  <x:String x:Key="Text.Progress.Merging" xml:space="preserve">Nag-me-merge ng '{0}' sa '{1}'...</x:String>
  <x:String x:Key="Text.Progress.MergeHeads" xml:space="preserve">Nag-me-merge ng head(s)...</x:String>
  <x:String x:Key="Text.Progress.MovingSubmodule" xml:space="preserve">Inililipat ang submodule...</x:String>
  <x:String x:Key="Text.Progress.PruneWorktrees" xml:space="preserve">Nililinis ang mga worktree...</x:String>
  <x:String x:Key="Text.Progress.PushRevision" xml:space="preserve">Push {0} -&gt; {1}...</x:String>
  <x:String x:Key="Text.Progress.Rebasing" xml:space="preserve">Rebase...</x:String>
  <x:String x:Key="Text.Progress.RemoveWorktree" xml:space="preserve">Tinatanggal ang worktree...</x:String>
  <x:String x:Key="Text.Progress.PruneRemote" xml:space="preserve">Pinapatakbo ang prune sa remote...</x:String>
  <x:String x:Key="Text.Progress.Pushing" xml:space="preserve">Push {0} -&gt; {1}/{2}...</x:String>
  <x:String x:Key="Text.Progress.PushingTag" xml:space="preserve">Pinapu-push ang tag...</x:String>
  <x:String x:Key="Text.Progress.RenamingBranch" xml:space="preserve">Pinapalitan ang pangalan ng '{0}'</x:String>
  <x:String x:Key="Text.Progress.Resetting" xml:space="preserve">Nire-reset ang kasalukuyang branch sa {0}...</x:String>
  <x:String x:Key="Text.Progress.ResettingWithoutCheckout" xml:space="preserve">Nire-reset ang {0} sa {1}...</x:String>
  <x:String x:Key="Text.Progress.Reverting" xml:space="preserve">Nire-revert ang commit '{0}'...</x:String>
  <x:String x:Key="Text.Progress.EditingHeadMessage" xml:space="preserve">Ine-edit ang HEAD message...</x:String>
  <x:String x:Key="Text.Progress.ScanningRepositories" xml:space="preserve">Ini-scan ang mga repository sa '{0}'...</x:String>
  <x:String x:Key="Text.Progress.SetSubmoduleBranch" xml:space="preserve">Sine-set ang branch ng submodule...</x:String>
  <x:String x:Key="Text.Progress.SettingUpstream" xml:space="preserve">Sine-set ang upstream...</x:String>
  <x:String x:Key="Text.Progress.StashingChanges" xml:space="preserve">Sine-stash ang mga pagbabago...</x:String>
  <x:String x:Key="Text.GitError.IndexLock" xml:space="preserve">Maaaring may ibang proseso ng git na tumatakbo. Kung wala, tanggalin ang .lock file sa .git directory.</x:String>
  <x:String x:Key="Text.GitError.MergeConflict" xml:space="preserve">May nakitang merge conflict. Ayusin ang mga conflict sa bawat file, pagkatapos i-stage at i-commit.</x:String>
  <x:String x:Key="Text.GitError.DetachedHead" xml:space="preserve">Ang HEAD ay naka-detach. Gumawa ng bagong branch para mapanatili ang iyong mga pagbabago.</x:String>
  <x:String x:Key="Text.GitError.PushRejected" xml:space="preserve">Tinanggihan ang push dahil may mas bagong pagbabago sa remote. Mag-pull (o mag-fetch at merge) muna, pagkatapos mag-push ulit.</x:String>
  <x:String x:Key="Text.GitError.UncommittedChanges" xml:space="preserve">May mga pagbabagong hindi pa naka-commit. I-commit o i-stash ang mga ito bago magpatuloy.</x:String>
  <x:String x:Key="Text.GitError.AuthFailed" xml:space="preserve">Nabigo ang authentication. Suriin ang iyong credentials, SSH key, o personal access token.</x:String>
  <x:String x:Key="Text.GitError.KeyPermissionTooOpen" xml:space="preserve">Masyadong bukas ang permissions ng SSH private key file. Ang key file ay dapat na accessible lamang ng may-ari (chmod 600).</x:String>
  <x:String x:Key="Text.GitError.KeyPermissionTooOpen.Fix" xml:space="preserve">Ayusin ang permissions (chmod 600)</x:String>
  <x:String x:Key="Text.GitError.RemoteNotFound" xml:space="preserve">Hindi nahanap ang remote repository. I-verify ang URL at ang iyong koneksyon sa network.</x:String>
  <x:String x:Key="Text.GitError.AlreadyExists" xml:space="preserve">May branch o tag na may ganitong pangalan. Pumili ng ibang pangalan.</x:String>
  <x:String x:Key="Text.GitError.UntrackedOverwritten" xml:space="preserve">Ang mga hindi sinusubaybayang file ay mapapatungan. Ilipat o tanggalin ang mga ito, o gamitin ang stash.</x:String>
  <x:String x:Key="Text.GitError.NetworkError" xml:space="preserve">Nabigo ang koneksyon sa network. Suriin ang iyong koneksyon sa internet at proxy settings.</x:String>
  <x:String x:Key="Text.GitError.RebaseInProgress" xml:space="preserve">May rebase na nagaganap. Ituloy, laktawan, o i-abort muna ang kasalukuyang rebase.</x:String>
  <x:String x:Key="Text.GitError.NothingToCommit" xml:space="preserve">Walang naka-stage na pagbabago para i-commit. Mag-stage ng mga file muna.</x:String>
  <x:String x:Key="Text.GitError.SubmoduleError" xml:space="preserve">May problema sa submodule. Subukan ang 'git submodule update --init --recursive'.</x:String>
  <x:String x:Key="Text.GitError.LfsError" xml:space="preserve">Hindi naka-install o hindi naka-configure ang Git LFS. I-install ang Git LFS at patakbuhin ang 'git lfs install'.</x:String>
  <x:String x:Key="Text.GitError.FileTooLarge" xml:space="preserve">Lumampas ang file sa limitasyon ng laki. Gamitin ang Git LFS para sa malalaking file.</x:String>
  <x:String x:Key="Text.GitError.CherryPickConflict" xml:space="preserve">May conflict ang cherry-pick. Ayusin ang mga conflict, pagkatapos patakbuhin ang 'git cherry-pick --continue' o '--abort'.</x:String>
  <x:String x:Key="Text.GitError.MergeNotFinished" xml:space="preserve">Hindi pa natapos ang nakaraang merge. Patakbuhin ang 'git merge --abort' para i-cancel, o ayusin at i-commit.</x:String>
  <x:String x:Key="Text.GitError.NoUpstream" xml:space="preserve">Walang nakatakdang upstream branch. Gamitin ang 'git push -u origin &lt;branch&gt;' para itakda ang tracking.</x:String>
  <x:String x:Key="Text.GitError.ShallowClone" xml:space="preserve">Ito ay shallow clone na may limitadong kasaysayan. Patakbuhin ang 'git fetch --unshallow' para makuha ang buong kasaysayan.</x:String>
  <x:String x:Key="Text.GitError.DiskFull" xml:space="preserve">Walang sapat na espasyo sa disk. Magpalaya ng espasyo at subukan ulit.</x:String>
  <x:String x:Key="Text.GitError.PermissionDenied" xml:space="preserve">Tinanggihan ang pahintulot sa file system. Suriin ang mga pahintulot ng file/directory o patakbuhin na may tamang pribilehiyo.</x:String>
  <x:String x:Key="Text.GitError.InvalidRef" xml:space="preserve">Hindi valid ang pangalan ng reference o revision. Suriin kung may typo sa pangalan ng branch, tag, o commit.</x:String>
  <x:String x:Key="Text.GitError.RemoteRefNotFound" xml:space="preserve">Hindi nahanap ang remote branch o reference. Maaaring na-delete na. Patakbuhin ang 'git fetch --prune' para i-update.</x:String>
  <x:String x:Key="Text.GitError.CorruptObject" xml:space="preserve">May sira o nawawalang object sa repository. Subukan ang 'git fsck' para mag-diagnose, o mag-clone ulit kung kailangan.</x:String>
  <x:String x:Key="Text.GitError.NotARepo" xml:space="preserve">Hindi git repository ang directory na ito. Patakbuhin ang 'git init' para gumawa, o suriin ang path.</x:String>
  <x:String x:Key="Text.GitError.StashError" xml:space="preserve">Walang nakitang stash entry. Walang naka-save na pagbabago para i-apply.</x:String>
  <x:String x:Key="Text.GitError.FilterError" xml:space="preserve">Nabigo ang clean/smudge filter. Suriin ang .gitattributes at ang filter configuration.</x:String>
  <x:String x:Key="Text.GitError.HookFailed" xml:space="preserve">Tinanggihan ng git hook ang operasyon. Suriin ang hook script o gamitin ang '--no-verify' para i-bypass (mag-ingat).</x:String>
  <x:String x:Key="Text.GitError.PatchFailed" xml:space="preserve">Hindi nai-apply nang maayos ang patch. Maaaring nagbago na ang target files. Subukang ayusin nang manu-mano.</x:String>
  <x:String x:Key="Text.GitError.HostKeyChanged" xml:space="preserve">Nagbago ang SSH key ng remote host mula sa huling koneksyon. Maaaring muling na-install ang server o na-update ang key nito. Alisin ang lumang key mula sa ~/.ssh/known_hosts at subukan ulit.</x:String>
  <x:String x:Key="Text.GitError.HostKeyVerifyFailed" xml:space="preserve">Nabigo ang SSH host key verification. Maaaring wala ang host sa iyong ~/.ssh/known_hosts file. Subukang kumonekta mula sa terminal upang idagdag ang host key, o suriin ang iyong SSH configuration.</x:String>
  <x:String x:Key="Text.GitError.WorktreeError" xml:space="preserve">Worktree conflict: maaaring naka-checkout na ang branch sa ibang lugar. Suriin gamit ang 'git worktree list'.</x:String>
</ResourceDictionary>
