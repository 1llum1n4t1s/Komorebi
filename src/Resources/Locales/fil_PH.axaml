  <x:String x:Key="Text.Configure.CommitMessageTemplate" xml:space="preserve">TEMPLATE NG COMMIT</x:String>
  <x:String x:Key="Text.Configure.CommitMessageTemplate.BuiltinVars" xml:space="preserve">Mga built-in na parameter:&#xD;&#xD;&#xD;&#xD;&#xD;
&#xD;&#xD;&#xD;&#xD;&#xD;
  ${branch_name} Pangalan ng kasalukuyang lokal na branch.&#xD;&#xD;&#xD;&#xD;&#xD;
  ${files_num} Bilang ng mga nabagong file&#xD;&#xD;&#xD;&#xD;&#xD;
  ${files} Mga path ng nabagong file&#xD;&#xD;&#xD;&#xD;&#xD;
  ${files:N} Hanggang N na bilang ng mga path ng nabagong file&#xD;&#xD;&#xD;&#xD;&#xD;
  ${pure_files} Katulad ng ${files}, ngunit mga pangalan ng file lamang&#xD;&#xD;&#xD;&#xD;&#xD;
