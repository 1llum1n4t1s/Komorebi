  <x:String x:Key="Text.Configure.CommitMessageTemplate.BuiltinVars" xml:space="preserve">Parametri intrinseci:&#xD;&#xD;
&#xD;&#xD;
  ${branch_name} Nomen rami localis praesentis.&#xD;&#xD;
  ${files_num} Numerus documentorum mutatorum&#xD;&#xD;
  ${files} Semitae documentorum mutatorum&#xD;&#xD;
  ${files:N} Maxime N semitae documentorum mutatorum&#xD;&#xD;
  ${pure_files} Ut ${files}, sed solum nomina documentorum&#xD;&#xD;
  ${pure_files:N} Ut ${files:N}, sed sine fasciculis</x:String>
  <x:String x:Key="Text.Configure.CommitMessageTemplate.Content" xml:space="preserve">Contentum Exemplaris:</x:String>
  <x:String x:Key="Text.Configure.CommitMessageTemplate.Name" xml:space="preserve">Nomen Exemplaris:</x:String>
  <x:String x:Key="Text.Configure.CustomAction" xml:space="preserve">ACTIO PROPRIA</x:String>
  <x:String x:Key="Text.Configure.CustomAction.Arguments" xml:space="preserve">Argumenta:</x:String>
  <x:String x:Key="Text.Configure.CustomAction.Arguments.Tip" xml:space="preserve">Parametri intrinseci:&#xD;&#xD;
&#xD;&#xD;
  ${REPO} Semita repositorii&#xD;&#xD;
  ${REMOTE} Remotum selectum vel remotum rami selecti&#xD;&#xD;
  ${BRANCH} Ramus selectus, sine ${REMOTE} parte pro ramis remotis&#xD;&#xD;
  ${BRANCH_FRIENDLY_NAME} Nomen amicum rami selecti, continet ${REMOTE} partem pro ramis remotis&#xD;&#xD;
  ${SHA} Hash committi selecti&#xD;&#xD;
  ${TAG} Signum selectum&#xD;&#xD;
  ${FILE} Documentum selectum, relativum ad radicem repositorii&#xD;&#xD;
