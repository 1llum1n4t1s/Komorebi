  <x:String x:Key="Text.Progress.DropHead" xml:space="preserve">HEAD '{0}' abiciendo...</x:String>
  <x:String x:Key="Text.Progress.DroppingStash" xml:space="preserve">Stash abiciendo: {0}</x:String>
  <x:String x:Key="Text.Progress.EditingRemote" xml:space="preserve">Remote '{0}' emendando...</x:String>
  <x:String x:Key="Text.Progress.RunCustomAction" xml:space="preserve">Actionem propriam exsequendo...</x:String>
  <x:String x:Key="Text.Progress.FastForward" xml:space="preserve">Fast-Forward...</x:String>
  <x:String x:Key="Text.Progress.GitFlowFinish" xml:space="preserve">Git Flow - {0} perficiendo...</x:String>
  <x:String x:Key="Text.Progress.GitFlowStart" xml:space="preserve">Git Flow - {0} incipiendo...</x:String>
  <x:String x:Key="Text.Progress.InitRepo" xml:space="preserve">Repositorium Git initiando in: '{0}'</x:String>
  <x:String x:Key="Text.Progress.InitGitFlow" xml:space="preserve">Git-flow initiando...</x:String>
  <x:String x:Key="Text.Progress.LFSFetch" xml:space="preserve">Objecta LFS a remote accipiendo...</x:String>
  <x:String x:Key="Text.Progress.LFSPrune" xml:space="preserve">LFS prune...</x:String>
  <x:String x:Key="Text.Progress.LFSPull" xml:space="preserve">Objecta LFS a remote trahendo...</x:String>
  <x:String x:Key="Text.Progress.LFSPush" xml:space="preserve">Objecta LFS ad remote pellendo...</x:String>
  <x:String x:Key="Text.Progress.LFSTrack" xml:space="preserve">Exemplar LFS proprium addendo...</x:String>
  <x:String x:Key="Text.Progress.Merging" xml:space="preserve">'{0}' in '{1}' mergendo...</x:String>
  <x:String x:Key="Text.Progress.MergeHeads" xml:space="preserve">Head(s) mergendo...</x:String>
  <x:String x:Key="Text.Progress.MovingSubmodule" xml:space="preserve">Submodulum movendo...</x:String>
  <x:String x:Key="Text.Progress.PruneWorktrees" xml:space="preserve">Worktrees purgando...</x:String>
  <x:String x:Key="Text.Progress.PushRevision" xml:space="preserve">Push {0} -&gt; {1}...</x:String>
  <x:String x:Key="Text.Progress.Rebasing" xml:space="preserve">Rebase...</x:String>
  <x:String x:Key="Text.Progress.RemoveWorktree" xml:space="preserve">Worktree removendo...</x:String>
  <x:String x:Key="Text.Progress.PruneRemote" xml:space="preserve">Prune in remote exsequendo...</x:String>
  <x:String x:Key="Text.Progress.Pushing" xml:space="preserve">Push {0} -&gt; {1}/{2}...</x:String>
  <x:String x:Key="Text.Progress.PushingTag" xml:space="preserve">Tag pellendo...</x:String>
  <x:String x:Key="Text.Progress.RenamingBranch" xml:space="preserve">'{0}' renominando</x:String>
  <x:String x:Key="Text.Progress.Resetting" xml:space="preserve">Branch currentem ad {0} restituendo...</x:String>
  <x:String x:Key="Text.Progress.ResettingWithoutCheckout" xml:space="preserve">{0} ad {1} restituendo...</x:String>
  <x:String x:Key="Text.Progress.Reverting" xml:space="preserve">Commit '{0}' revertendo...</x:String>
  <x:String x:Key="Text.Progress.EditingHeadMessage" xml:space="preserve">Nuntium HEAD emendando...</x:String>
  <x:String x:Key="Text.Progress.ScanningRepositories" xml:space="preserve">Repositoria sub '{0}' explorando...</x:String>
  <x:String x:Key="Text.Progress.SetSubmoduleBranch" xml:space="preserve">Branch submoduli statuendo...</x:String>
  <x:String x:Key="Text.Progress.SettingUpstream" xml:space="preserve">Upstream statuendo...</x:String>
  <x:String x:Key="Text.Progress.StashingChanges" xml:space="preserve">Mutationes recondendo...</x:String>
  <x:String x:Key="Text.GitError.IndexLock" xml:space="preserve">Fortasse alius processus git currit. Si non, dele fasciculum .lock in directorio .git.</x:String>
  <x:String x:Key="Text.GitError.MergeConflict" xml:space="preserve">Conflictus fusionum detecti sunt. Resolve conflictus in singulis fasciculis, deinde colloca et committe.</x:String>
  <x:String x:Key="Text.GitError.DetachedHead" xml:space="preserve">HEAD seiunctum est. Crea novum ramum ut mutationes tuas serves.</x:String>
  <x:String x:Key="Text.GitError.PushRejected" xml:space="preserve">Propulsio reiecta est quia repositorium remotum mutationes recentiores habet. Prius trahe (vel arcessere et fundere), deinde iterum propelle.</x:String>
  <x:String x:Key="Text.GitError.UncommittedChanges" xml:space="preserve">Mutationes non commissae habes. Committe vel reconde eas antequam procedas.</x:String>
  <x:String x:Key="Text.GitError.AuthFailed" xml:space="preserve">Authenticatio defecit. Verifica credentialia, clavem SSH, vel signum accessus personalis.</x:String>
  <x:String x:Key="Text.GitError.RemoteNotFound" xml:space="preserve">Repositorium remotum non inventum. Verifica URL et conexionem retis.</x:String>
  <x:String x:Key="Text.GitError.AlreadyExists" xml:space="preserve">Ramus vel titulus eo nomine iam existit. Elige nomen diversum.</x:String>
  <x:String x:Key="Text.GitError.UntrackedOverwritten" xml:space="preserve">Fasciculi non vestigati superscribentur. Move vel dele eos, vel utere stash ad eos servandos.</x:String>
  <x:String x:Key="Text.GitError.NetworkError" xml:space="preserve">Conexio retis defecit. Verifica conexionem interretis et configurationem procuratoris.</x:String>
  <x:String x:Key="Text.GitError.RebaseInProgress" xml:space="preserve">Rebase in progressu est. Prius continua, praetermitte, vel abrumpe rebase currentem.</x:String>
  <x:String x:Key="Text.GitError.NothingToCommit" xml:space="preserve">Nullae mutationes collocatae ad committendum. Prius colloca fasciculos.</x:String>
  <x:String x:Key="Text.GitError.SubmoduleError" xml:space="preserve">Problema submoduli detectum. Tempta 'git submodule update --init --recursive' exsequi.</x:String>
  <x:String x:Key="Text.GitError.LfsError" xml:space="preserve">Git LFS non installatum vel non configuratum est. Installa Git LFS et exsequere 'git lfs install'.</x:String>
  <x:String x:Key="Text.GitError.FileTooLarge" xml:space="preserve">Fasciculus limitem magnitudinis excedit. Utere Git LFS ad fasciculos magnos vestigandos.</x:String>
  <x:String x:Key="Text.GitError.CherryPickConflict" xml:space="preserve">Cherry-pick conflictus effecit. Resolve conflictus, deinde exsequere 'git cherry-pick --continue' vel '--abort'.</x:String>
  <x:String x:Key="Text.GitError.MergeNotFinished" xml:space="preserve">Fusio prior non completa est. Exsequere 'git merge --abort' ad cancellandum, vel resolve et committe.</x:String>
  <x:String x:Key="Text.GitError.NoUpstream" xml:space="preserve">Nulla upstream ramus constituta est. Utere 'git push -u origin &lt;ramus&gt;' ad vestigationem constituendam.</x:String>
  <x:String x:Key="Text.GitError.ShallowClone" xml:space="preserve">Hoc est clonum superficiale cum historia limitata. Exsequere 'git fetch --unshallow' ad plenam historiam obtinendam.</x:String>
  <x:String x:Key="Text.GitError.DiskFull" xml:space="preserve">Spatium disci non sufficit. Libera spatium et iterum tempta.</x:String>
  <x:String x:Key="Text.GitError.PermissionDenied" xml:space="preserve">Permissio systematis fasciculorum denegata. Verifica permissiones fasciculorum vel exsequere cum privilegiis aptis.</x:String>
  <x:String x:Key="Text.GitError.InvalidRef" xml:space="preserve">Nomen referentiae vel revisionis invalidum. Verifica errores typographicos in nomine rami, tituli vel commissi.</x:String>
  <x:String x:Key="Text.GitError.RemoteRefNotFound" xml:space="preserve">Ramus vel referentia remota non inventa. Fortasse deleta est. Exsequere 'git fetch --prune' ad renovandum.</x:String>
  <x:String x:Key="Text.GitError.CorruptObject" xml:space="preserve">Repositorium obiecta corrupta vel amissa habet. Tempta 'git fsck' ad diagnosim, vel re-clona si necesse.</x:String>
  <x:String x:Key="Text.GitError.NotARepo" xml:space="preserve">Hoc directorium non est repositorium git. Exsequere 'git init' ad creandum, vel verifica viam.</x:String>
  <x:String x:Key="Text.GitError.StashError" xml:space="preserve">Nullae notae stash inventae. Nullae mutationes servatae ad applicandum.</x:String>
  <x:String x:Key="Text.GitError.FilterError" xml:space="preserve">Filtrum clean/smudge defecit. Verifica .gitattributes et configurationem filtri.</x:String>
  <x:String x:Key="Text.GitError.HookFailed" xml:space="preserve">Uncus git operationem reiecit. Verifica scriptum unci vel utere '--no-verify' ad praetereundum (caute).</x:String>
  <x:String x:Key="Text.GitError.PatchFailed" xml:space="preserve">Sartura munde applicari non potuit. Fasciculi destinationis mutati esse possunt. Tempta manualiter solvere.</x:String>
  <x:String x:Key="Text.GitError.WorktreeError" xml:space="preserve">Conflictus worktree: ramus iam alibi extractus esse potest. Verifica cum 'git worktree list'.</x:String>
</ResourceDictionary>
