  <x:String x:Key="Text.TagCM.Push" xml:space="preserve">தள்ளு ${0}$...</x:String>
  <x:String x:Key="Text.UpdateSubmodules" xml:space="preserve">துணைத்தொகுதிகளைப் புதுப்பி</x:String>
  <x:String x:Key="Text.UpdateSubmodules.All" xml:space="preserve">அனைத்து துணைத்தொகுதிகள்</x:String>
  <x:String x:Key="Text.UpdateSubmodules.Init" xml:space="preserve">தேவைக்கேற்றப துவக்கு</x:String>
  <x:String x:Key="Text.UpdateSubmodules.Target" xml:space="preserve">Submodule:</x:String>
  <x:String x:Key="Text.UpdateSubmodules.UpdateToRemoteTrackingBranch" xml:space="preserve">Submodule-இன் remote tracking கிளைக்கு புதுப்பி</x:String>
  <x:String x:Key="Text.URL" xml:space="preserve">முகவரி:</x:String>
  <x:String x:Key="Text.ViewLogs" xml:space="preserve">பதிவுகள்</x:String>
  <x:String x:Key="Text.ViewLogs.Clear" xml:space="preserve">அனைத்தையும் அழி</x:String>
  <x:String x:Key="Text.ViewLogs.CopyLog" xml:space="preserve">நகலெடு</x:String>
  <x:String x:Key="Text.ViewLogs.Delete" xml:space="preserve">நீக்கு</x:String>
  <x:String x:Key="Text.Warn" xml:space="preserve">முன்னறிவிப்பு</x:String>
  <x:String x:Key="Text.Welcome" xml:space="preserve">வரவேற்பு பக்கம்</x:String>
  <x:String x:Key="Text.Welcome.AddRootFolder" xml:space="preserve">குழுவை உருவாக்கு</x:String>
  <x:String x:Key="Text.Welcome.AddSubFolder" xml:space="preserve">துணைக் குழுவை உருவாக்கு</x:String>
  <x:String x:Key="Text.Welcome.Clone" xml:space="preserve">நகலி களஞ்சியம்</x:String>
  <x:String x:Key="Text.Welcome.Delete" xml:space="preserve">நீக்கு</x:String>
  <x:String x:Key="Text.Welcome.DragDropTip" xml:space="preserve">கோப்புறையை இழுத்து &amp; விடு ஆதரிக்கப்படுகிறது. தனிப்பயன் குழுவாக்க ஆதரவு.</x:String>
  <x:String x:Key="Text.Welcome.Edit" xml:space="preserve">திருத்து</x:String>
  <x:String x:Key="Text.Welcome.Move" xml:space="preserve">வேறொரு குழுவிற்கு நகர்த்து</x:String>
  <x:String x:Key="Text.Welcome.OpenAllInNode" xml:space="preserve">அனைத்து களஞ்சியங்களையும் திற</x:String>
  <x:String x:Key="Text.Welcome.OpenOrInit" xml:space="preserve">களஞ்சியத்தைத் திற</x:String>
  <x:String x:Key="Text.Welcome.OpenTerminal" xml:space="preserve">முனையத்தைத் திற</x:String>
  <x:String x:Key="Text.Welcome.ScanDefaultCloneDir" xml:space="preserve">இயல்புநிலை நகலி அடைவில் களஞ்சியங்களை மீண்டும் வருடு</x:String>
  <x:String x:Key="Text.Welcome.Search" xml:space="preserve">களஞ்சியங்களைத் தேடு...</x:String>
  <x:String x:Key="Text.WorkingCopy" xml:space="preserve">உள்ளக மாற்றங்கள்</x:String>
  <x:String x:Key="Text.WorkingCopy.AddToGitIgnore" xml:space="preserve">அறிவிலி புறக்கணி</x:String>
  <x:String x:Key="Text.WorkingCopy.AddToGitIgnore.Extension" xml:space="preserve">எல்லா *{0} கோப்புகளையும் புறக்கணி</x:String>
  <x:String x:Key="Text.WorkingCopy.AddToGitIgnore.ExtensionInSameFolder" xml:space="preserve">ஒரே கோப்புறையில் *{0} கோப்புகளைப் புறக்கணி</x:String>
  <x:String x:Key="Text.WorkingCopy.AddToGitIgnore.InFolder" xml:space="preserve">'{0}' கோப்புறையை புறக்கணி</x:String>
  <x:String x:Key="Text.WorkingCopy.AddToGitIgnore.SingleFile" xml:space="preserve">இந்த கோப்பை மட்டும் புறக்கணி</x:String>
  <x:String x:Key="Text.WorkingCopy.AddToGitIgnore.TopFolder" xml:space="preserve">'{0}' கோப்புறையை புறக்கணி</x:String>
  <x:String x:Key="Text.WorkingCopy.Amend" xml:space="preserve">பின்னொட்டு</x:String>
  <x:String x:Key="Text.WorkingCopy.CanStageTip" xml:space="preserve">இந்த கோப்பை இப்போது நீங்கள் நிலைப்படுத்தலாம்.</x:String>
  <x:String x:Key="Text.WorkingCopy.ClearCommitHistories" xml:space="preserve">வரலாற்றை அழி</x:String>
  <x:String x:Key="Text.WorkingCopy.ClearCommitHistories.Confirm" xml:space="preserve">அனைத்து commit செய்தி வரலாற்றையும் அழிக்க விரும்புகிறீர்களா? இந்தச் செயலை மீட்க இயலாது.</x:String>
  <x:String x:Key="Text.WorkingCopy.Commit" xml:space="preserve">உறுதிமொழி</x:String>
  <x:String x:Key="Text.WorkingCopy.CommitAndPush" xml:space="preserve">உறுதிமொழி &amp; தள்ளு</x:String>
  <x:String x:Key="Text.WorkingCopy.CommitMessageHelper" xml:space="preserve">வளர்புரு/வரலாறுகள்</x:String>
  <x:String x:Key="Text.WorkingCopy.CommitTip" xml:space="preserve">சொடுக்கு நிகழ்வைத் தூண்டு</x:String>
  <x:String x:Key="Text.WorkingCopy.CommitToEdit" xml:space="preserve">உறுதிமொழி (திருத்து)</x:String>
  <x:String x:Key="Text.WorkingCopy.CommitWithAutoStage" xml:space="preserve">அனைத்து மாற்றங்களையும் நிலைப்படுத்தி உறுதிமொழி</x:String>
  <x:String x:Key="Text.WorkingCopy.ConfirmCommitWithDetachedHead" xml:space="preserve">நீங்கள் ஒரு பிரிந்த HEAD-இல் commit உருவாக்குகிறீர்கள். தொடர விரும்புகிறீர்களா?</x:String>
  <x:String x:Key="Text.WorkingCopy.ConfirmCommitWithFilter">நீங்கள் {0} கோப்புகளை நிலைப்படுத்தியுள்ளீர்கள், ஆனால் {1} கோப்புகள் மட்டுமே காட்டப்பட்டுள்ளன ({2} கோப்புகள் வடிகட்டப்பட்டுள்ளன). தொடர விரும்புகிறீர்களா?</x:String>
  <x:String x:Key="Text.WorkingCopy.Conflicts" xml:space="preserve">மோதல்கள் கண்டறியப்பட்டது</x:String>
  <x:String x:Key="Text.WorkingCopy.Conflicts.Merge" xml:space="preserve">MERGE</x:String>
  <x:String x:Key="Text.WorkingCopy.Conflicts.MergeExternal" xml:space="preserve">வெளிப்புறக் கருவியுடன் Merge செய்</x:String>
  <x:String x:Key="Text.WorkingCopy.Conflicts.OpenExternalMergeToolAllConflicts" xml:space="preserve">அனைத்து முரண்பாடுகளையும் வெளிப்புற MERGETOOL-இல் திற</x:String>
  <x:String x:Key="Text.WorkingCopy.Conflicts.Resolved" xml:space="preserve">கோப்பு மோதல்கள் தீர்க்கப்பட்டது</x:String>
  <x:String x:Key="Text.WorkingCopy.Conflicts.UseMine" xml:space="preserve">என்னுடையதைப் பயன்படுத்து</x:String>
  <x:String x:Key="Text.WorkingCopy.Conflicts.UseTheirs" xml:space="preserve">அவர்களுடையதைப் பயன்படுத்து</x:String>
  <x:String x:Key="Text.WorkingCopy.IncludeUntracked" xml:space="preserve">கண்காணிக்கப்படாத கோப்புகளைச் சேர்</x:String>
  <x:String x:Key="Text.WorkingCopy.NoCommitHistories" xml:space="preserve">அண்மைக் கால உள்ளீட்டு செய்திகள் இல்லை</x:String>
  <x:String x:Key="Text.WorkingCopy.NoCommitTemplates" xml:space="preserve">உறுதிமொழி வளர்புருகள் இல்லை</x:String>
  <x:String x:Key="Text.WorkingCopy.NoVerify" xml:space="preserve">சரிபார்ப்பு இல்லை</x:String>
  <x:String x:Key="Text.WorkingCopy.ResetAuthor" xml:space="preserve">ஆசிரியரை Reset செய்</x:String>
  <x:String x:Key="Text.WorkingCopy.SignOff" xml:space="preserve">கையெழுத்திடு</x:String>
  <x:String x:Key="Text.WorkingCopy.Staged" xml:space="preserve">நிலைபடுத்தியது</x:String>
  <x:String x:Key="Text.WorkingCopy.Staged.Unstage" xml:space="preserve">நிலைநீக்கு</x:String>
  <x:String x:Key="Text.WorkingCopy.Staged.UnstageAll" xml:space="preserve">அனைத்தும் நிலைநீக்கு</x:String>
  <x:String x:Key="Text.WorkingCopy.Unstaged" xml:space="preserve">நிலைநீக்கு</x:String>
  <x:String x:Key="Text.WorkingCopy.Unstaged.Stage" xml:space="preserve">நிலைபடுத்து</x:String>
  <x:String x:Key="Text.WorkingCopy.Unstaged.StageAll" xml:space="preserve">அனைத்தும் நிலைபடுத்து</x:String>
  <x:String x:Key="Text.WorkingCopy.Unstaged.ViewAssumeUnchanged" xml:space="preserve">மாறாதது எனநினைப்பதை பார்</x:String>
  <x:String x:Key="Text.WorkingCopy.UseCommitTemplate" xml:space="preserve">வளர்புரு: ${0}$</x:String>
  <x:String x:Key="Text.Workspace" xml:space="preserve">பணியிடம்:</x:String>
  <x:String x:Key="Text.Workspace.Configure" xml:space="preserve">பணியிடங்களை உள்ளமை...</x:String>
  <x:String x:Key="Text.Worktree" xml:space="preserve">பணிமரம்</x:String>
  <x:String x:Key="Text.Worktree.Branch" xml:space="preserve">BRANCH</x:String>
  <x:String x:Key="Text.Worktree.CopyPath" xml:space="preserve">பாதையை நகலெடு</x:String>
  <x:String x:Key="Text.Worktree.Head" xml:space="preserve">HEAD</x:String>
  <x:String x:Key="Text.Worktree.Lock" xml:space="preserve">பூட்டு</x:String>
  <x:String x:Key="Text.Worktree.Open" xml:space="preserve">திற</x:String>
  <x:String x:Key="Text.Worktree.Path" xml:space="preserve">PATH</x:String>
  <x:String x:Key="Text.Worktree.Remove" xml:space="preserve">நீக்கு</x:String>
  <x:String x:Key="Text.Worktree.Unlock" xml:space="preserve">திற</x:String>
  <x:String x:Key="Text.Yes" xml:space="preserve">ஆம்</x:String>
  <x:String x:Key="Text.Error.BisectHasLocalChanges" xml:space="preserve">உறுதிப்படுத்தப்படாத உள்ளூர் மாற்றங்கள் உள்ளன. முதலில் அவற்றை நிராகரிக்கவும் அல்லது stash செய்யவும்.</x:String>
  <x:String x:Key="Text.Error.BisectAlreadyRunning" xml:space="preserve">Bisect இயங்குகிறது! புதியதை தொடங்கும் முன் நிறுத்தவும்.</x:String>
  <x:String x:Key="Text.Error.ConflictAndNonConflictMixed" xml:space="preserve">தேர்வில் முரண்பாடான மற்றும் முரண்பாடற்ற மாற்றங்கள் இரண்டும் உள்ளன!</x:String>
  <x:String x:Key="Text.Error.FailedToSelectLocation" xml:space="preserve">இடத்தைத் தேர்வு செய்ய இயலவில்லை: {0}</x:String>
  <x:String x:Key="Text.Error.FailedToSelectFolder" xml:space="preserve">மூல கோப்புறையைத் தேர்வு செய்ய இயலவில்லை: {0}</x:String>
  <x:String x:Key="Text.Error.FailedToSaveAsPatch" xml:space="preserve">Patch ஆகச் சேமிக்க இயலவில்லை: {0}</x:String>
  <x:String x:Key="Text.Error.FailedToSaveFile" xml:space="preserve">கோப்பைச் சேமிக்க இயலவில்லை: {0}</x:String>
  <x:String x:Key="Text.Error.FailedToSelectCloneDir" xml:space="preserve">இயல்பு clone கோப்பகத்தைத் தேர்வு செய்ய இயலவில்லை: {0}</x:String>
  <x:String x:Key="Text.Error.FailedToSelectGitExe" xml:space="preserve">Git இயங்கு கோப்பைத் தேர்வு செய்ய இயலவில்லை: {0}</x:String>
  <x:String x:Key="Text.Error.FailedToSelectGpg" xml:space="preserve">GPG நிரலைத் தேர்வு செய்ய இயலவில்லை: {0}</x:String>
  <x:String x:Key="Text.Error.FailedToSelectTerminal" xml:space="preserve">Shell/terminal தேர்வு செய்ய இயலவில்லை: {0}</x:String>
  <x:String x:Key="Text.Error.FailedToSelectMergeTool" xml:space="preserve">Merge கருவியைத் தேர்வு செய்ய இயலவில்லை: {0}</x:String>
  <x:String x:Key="Text.Error.FailedToSelectCustomAction" xml:space="preserve">தனிப்பயன் செயலுக்கான நிரலைத் தேர்வு செய்ய இயலவில்லை: {0}</x:String>
  <x:String x:Key="Text.Error.FailedToSelectScanDir" xml:space="preserve">ஸ்கேன் மூல கோப்பகத்தைத் தேர்வு செய்ய இயலவில்லை: {0}</x:String>
  <x:String x:Key="Text.Error.FailedToOpenRepository" xml:space="preserve">களஞ்சியத்தைத் திறக்க இயலவில்லை: {0}</x:String>
  <x:String x:Key="Text.Error.FailedToDiscard" xml:space="preserve">மாற்றங்களை நிராகரிக்க இயலவில்லை. காரணம்: {0}</x:String>
  <x:String x:Key="Text.Error.FailedToGenerateCommitMessage" xml:space="preserve">Commit செய்தியை உருவாக்க இயலவில்லை: {0}</x:String>
  <x:String x:Key="Text.Error.FailedToQueryCommits" xml:space="preserve">Commits வினவ இயலவில்லை. காரணம்: {0}</x:String>
  <x:String x:Key="Text.Error.FailedToQueryInteractiveRebase" xml:space="preserve">ஊடாடும் rebase க்கான commits வினவ இயலவில்லை. காரணம்: {0}</x:String>
  <x:String x:Key="Text.Error.FailedToQueryFileContent" xml:space="preserve">கோப்பு உள்ளடக்கத்தை வினவ இயலவில்லை: {0}</x:String>
  <x:String x:Key="Text.Error.FailedToUpdateIndex" xml:space="preserve">அட்டவணையைப் புதுப்பிக்க இயலவில்லை: {0}</x:String>
  <x:String x:Key="Text.Error.FailedToSaveRevisionFile" xml:space="preserve">கோப்பைச் சேமிக்க இயலவில்லை: {0}</x:String>
  <x:String x:Key="Text.Error.FailedToSavePatch" xml:space="preserve">Patch மாற்றத்தைச் சேமிக்க இயலவில்லை: {0}</x:String>
  <x:String x:Key="Text.Error.FailedToScanRepositories" xml:space="preserve">களஞ்சியங்களை ஸ்கேன் செய்ய இயலவில்லை: {0}</x:String>
  <x:String x:Key="Text.Error.FailedToStartWatcher" xml:space="preserve">களஞ்சியம் '{0}' க்கான கண்காணியை தொடங்க இயலவில்லை. கைமுறையாகப் புதுப்பிக்க 'F5' அழுத்தவும்!&#xD;
காரணம்: {1}</x:String>
  <x:String x:Key="Text.Error.FailedToStartTerminal" xml:space="preserve">'{0}' ஐத் தொடங்க இயலவில்லை. காரணம்: {1}</x:String>
  <x:String x:Key="Text.Error.FailedToOpenFile" xml:space="preserve">திறக்க இயலவில்லை: {0}</x:String>
  <x:String x:Key="Text.Error.NoFilesForCommit" xml:space="preserve">Commit க்கு கோப்புகள் சேர்க்கப்படவில்லை!</x:String>
  <x:String x:Key="Text.Error.BadOpenAIConfig" xml:space="preserve">OpenAI அமைப்பு தவறானது</x:String>
  <x:String x:Key="Text.Error.GitFlowNoBranch" xml:space="preserve">Git flow துவக்கம் தோல்வி: Branch கிடைக்கவில்லை!</x:String>
  <x:String x:Key="Text.Error.BadGitFlowBranchType" xml:space="preserve">தவறான git-flow branch வகை!</x:String>
  <x:String x:Key="Text.Error.FolderNotFound" xml:space="preserve">கோப்புறை '{0}' கிடைக்கவில்லை</x:String>
  <x:String x:Key="Text.Error.CanNotSquash" xml:space="preserve">தற்போதைய commit ஐ மூல commit இல் சுருக்க இயலாது!</x:String>
  <x:String x:Key="Text.Error.UnfinishedTasks" xml:space="preserve">திறந்த பக்கங்களில் முடிக்கப்படாத பணிகள் உள்ளன. காத்திருக்கவும்!</x:String>
  <x:String x:Key="Text.Error.RepositoryNotExist" xml:space="preserve">களஞ்சியம் இனி இல்லை. தயவுசெய்து நீக்கவும்.</x:String>
  <x:String x:Key="Text.Error.InvalidGitRepository" xml:space="preserve">கொடுக்கப்பட்ட பாதை செல்லுபடியான Git களஞ்சியம் அல்ல!</x:String>
  <x:String x:Key="Text.Error.NoRemotes" xml:space="preserve">இந்தக் களஞ்சியத்தில் remote சேர்க்கப்படவில்லை!</x:String>
  <x:String x:Key="Text.Error.CanNotFindBranch" xml:space="preserve">தற்போதைய branch கண்டுபிடிக்க இயலவில்லை!</x:String>
  <x:String x:Key="Text.Error.NoBranchBeforeFirstCommit" xml:space="preserve">முதல் commit க்கு முன் Git branch உருவாக்க இயலாது.</x:String>
  <x:String x:Key="Text.Error.MissingScanDir" xml:space="preserve">ஸ்கேன் மூல கோப்பகம் இல்லை!</x:String>
  <x:String x:Key="Text.Error.NoCommitsToAmend" xml:space="preserve">திருத்துவதற்கு commits இல்லை!</x:String>
  <x:String x:Key="Text.Error.RepoHasUnfinishedJob" xml:space="preserve">களஞ்சியத்தில் முடிக்கப்படாத பணி உள்ளது! காத்திருக்கவும்!</x:String>
  <x:String x:Key="Text.Error.RepoHasConflicts" xml:space="preserve">களஞ்சியத்தில் தீர்க்கப்படாத முரண்பாடுகள் உள்ளன. தானியங்கி stage மற்றும் commit முடக்கப்பட்டுள்ளது!</x:String>
  <x:String x:Key="Text.Error.TerminalNotSpecified" xml:space="preserve">Terminal குறிப்பிடப்படவில்லை! சரியான shell/terminal அமைக்கப்பட்டுள்ளதா உறுதிப்படுத்தவும்.</x:String>
  <x:String x:Key="Text.Progress.AddingSubmodule" xml:space="preserve">துணைத்தொகுதி சேர்க்கிறது...</x:String>
  <x:String x:Key="Text.Progress.AddingWorktree" xml:space="preserve">Worktree சேர்க்கிறது...</x:String>
  <x:String x:Key="Text.Progress.Archiving" xml:space="preserve">காப்பகப்படுத்துகிறது...</x:String>
  <x:String x:Key="Text.Progress.ApplyPatch" xml:space="preserve">Patch பயன்படுத்துகிறது...</x:String>
  <x:String x:Key="Text.Progress.AddingRemote" xml:space="preserve">Remote சேர்க்கிறது...</x:String>
  <x:String x:Key="Text.Progress.AddingIgnoredFiles" xml:space="preserve">புறக்கணிக்கப்பட்ட கோப்புகளைச் சேர்க்கிறது...</x:String>
  <x:String x:Key="Text.Progress.CheckoutAndFastForward" xml:space="preserve">Checkout மற்றும் Fast-Forward '{0}'...</x:String>
  <x:String x:Key="Text.Progress.WaitingBranchUpdate" xml:space="preserve">Branch புதுப்பிப்புக்காகக் காத்திருக்கிறது...</x:String>
  <x:String x:Key="Text.Progress.CheckoutCommit" xml:space="preserve">Commit '{0}' checkout செய்கிறது...</x:String>
  <x:String x:Key="Text.Progress.ApplyingStash" xml:space="preserve">Stash பயன்படுத்துகிறது: {0}</x:String>
  <x:String x:Key="Text.Progress.Checkout" xml:space="preserve">Checkout '{0}'...</x:String>
  <x:String x:Key="Text.Progress.Cleanup" xml:space="preserve">சுத்தப்படுத்துகிறது (GC aggressive &amp; prune)...</x:String>
  <x:String x:Key="Text.Progress.CherryPick" xml:space="preserve">Cherry-Pick commit(s)...</x:String>
  <x:String x:Key="Text.Progress.ChangeSubmoduleUrl" xml:space="preserve">துணைத்தொகுதி URL மாற்றுகிறது...</x:String>
  <x:String x:Key="Text.Progress.ClearIndexCache" xml:space="preserve">அட்டவணை cache அழிக்கிறது...</x:String>
  <x:String x:Key="Text.Progress.ClearAllStashes" xml:space="preserve">அனைத்து stash அழிக்கிறது...</x:String>
  <x:String x:Key="Text.Progress.Cloning" xml:space="preserve">Clone செய்கிறது...</x:String>
  <x:String x:Key="Text.Progress.CreateTag" xml:space="preserve">Tag உருவாக்குகிறது...</x:String>
  <x:String x:Key="Text.Progress.DeinitSubmodule" xml:space="preserve">துணைத்தொகுதியை நிறுத்துகிறது</x:String>
  <x:String x:Key="Text.Progress.DeletingBranch" xml:space="preserve">Branch நீக்குகிறது...</x:String>
  <x:String x:Key="Text.Progress.DeletingMultipleTags" xml:space="preserve">பல tags நீக்குகிறது...</x:String>
  <x:String x:Key="Text.Progress.DeletingMultipleBranches" xml:space="preserve">பல branches நீக்குகிறது...</x:String>
  <x:String x:Key="Text.Progress.DeletingRemote" xml:space="preserve">Remote நீக்குகிறது...</x:String>
  <x:String x:Key="Text.Progress.DeletingSubmodule" xml:space="preserve">துணைத்தொகுதி நீக்குகிறது...</x:String>
  <x:String x:Key="Text.Progress.DeletingTag" xml:space="preserve">Tag '{0}' நீக்குகிறது...</x:String>
  <x:String x:Key="Text.Progress.DropHead" xml:space="preserve">HEAD '{0}' கைவிடுகிறது...</x:String>
  <x:String x:Key="Text.Progress.DroppingStash" xml:space="preserve">Stash கைவிடுகிறது: {0}</x:String>
  <x:String x:Key="Text.Progress.EditingRemote" xml:space="preserve">Remote '{0}' திருத்துகிறது...</x:String>
  <x:String x:Key="Text.Progress.RunCustomAction" xml:space="preserve">தனிப்பயன் செயலை இயக்குகிறது...</x:String>
  <x:String x:Key="Text.Progress.FastForward" xml:space="preserve">Fast-Forward...</x:String>
  <x:String x:Key="Text.Progress.GitFlowFinish" xml:space="preserve">Git Flow - {0} முடிக்கிறது...</x:String>
  <x:String x:Key="Text.Progress.GitFlowStart" xml:space="preserve">Git Flow - {0} தொடங்குகிறது...</x:String>
  <x:String x:Key="Text.Progress.InitRepo" xml:space="preserve">Git களஞ்சியத்தை துவக்குகிறது: '{0}'</x:String>
  <x:String x:Key="Text.Progress.InitGitFlow" xml:space="preserve">Git-flow துவக்குகிறது...</x:String>
  <x:String x:Key="Text.Progress.LFSFetch" xml:space="preserve">Remote இலிருந்து LFS பொருட்களைப் பெறுகிறது...</x:String>
  <x:String x:Key="Text.Progress.LFSPrune" xml:space="preserve">LFS prune...</x:String>
  <x:String x:Key="Text.Progress.LFSPull" xml:space="preserve">Remote இலிருந்து LFS பொருட்களை இழுக்கிறது...</x:String>
  <x:String x:Key="Text.Progress.LFSPush" xml:space="preserve">LFS பொருட்களை remote க்கு அனுப்புகிறது...</x:String>
  <x:String x:Key="Text.Progress.LFSTrack" xml:space="preserve">தனிப்பயன் LFS கண்காணிப்பு வடிவத்தைச் சேர்க்கிறது...</x:String>
  <x:String x:Key="Text.Progress.Merging" xml:space="preserve">'{0}' ஐ '{1}' இல் merge செய்கிறது...</x:String>
  <x:String x:Key="Text.Progress.MergeHeads" xml:space="preserve">Head(s) merge செய்கிறது...</x:String>
  <x:String x:Key="Text.Progress.MovingSubmodule" xml:space="preserve">துணைத்தொகுதியை நகர்த்துகிறது...</x:String>
  <x:String x:Key="Text.Progress.PruneWorktrees" xml:space="preserve">Worktrees சுத்தப்படுத்துகிறது...</x:String>
  <x:String x:Key="Text.Progress.PushRevision" xml:space="preserve">Push {0} -&gt; {1}...</x:String>
  <x:String x:Key="Text.Progress.Rebasing" xml:space="preserve">Rebase...</x:String>
  <x:String x:Key="Text.Progress.RemoveWorktree" xml:space="preserve">Worktree நீக்குகிறது...</x:String>
  <x:String x:Key="Text.Progress.PruneRemote" xml:space="preserve">Remote இல் prune இயக்குகிறது...</x:String>
  <x:String x:Key="Text.Progress.Pushing" xml:space="preserve">Push {0} -&gt; {1}/{2}...</x:String>
  <x:String x:Key="Text.Progress.PushingTag" xml:space="preserve">Tag push செய்கிறது...</x:String>
  <x:String x:Key="Text.Progress.RenamingBranch" xml:space="preserve">'{0}' மறுபெயரிடுகிறது</x:String>
  <x:String x:Key="Text.Progress.Resetting" xml:space="preserve">தற்போதைய branch ஐ {0} க்கு மீட்டமைக்கிறது...</x:String>
  <x:String x:Key="Text.Progress.ResettingWithoutCheckout" xml:space="preserve">{0} ஐ {1} க்கு மீட்டமைக்கிறது...</x:String>
  <x:String x:Key="Text.Progress.Reverting" xml:space="preserve">Commit '{0}' மாற்றியமைக்கிறது...</x:String>
  <x:String x:Key="Text.Progress.EditingHeadMessage" xml:space="preserve">HEAD செய்தியைத் திருத்துகிறது...</x:String>
  <x:String x:Key="Text.Progress.ScanningRepositories" xml:space="preserve">'{0}' கீழ் களஞ்சியங்களை ஸ்கேன் செய்கிறது...</x:String>
  <x:String x:Key="Text.Progress.SetSubmoduleBranch" xml:space="preserve">துணைத்தொகுதி branch அமைக்கிறது...</x:String>
  <x:String x:Key="Text.Progress.SettingUpstream" xml:space="preserve">Upstream அமைக்கிறது...</x:String>
  <x:String x:Key="Text.Progress.StashingChanges" xml:space="preserve">மாற்றங்களை stash செய்கிறது...</x:String>
  <x:String x:Key="Text.GitError.IndexLock" xml:space="preserve">வேறு git செயல்முறை இயங்கிக்கொண்டிருக்கலாம். இல்லையென்றால், .git கோப்பகத்தில் .lock கோப்பை நீக்கவும்.</x:String>
  <x:String x:Key="Text.GitError.MergeConflict" xml:space="preserve">இணைப்பு முரண்பாடுகள் கண்டறியப்பட்டன. ஒவ்வொரு கோப்பிலும் முரண்பாடுகளைத் தீர்த்து, நிலைப்படுத்தி உறுதிசெய்யவும்.</x:String>
  <x:String x:Key="Text.GitError.DetachedHead" xml:space="preserve">HEAD பிரிக்கப்பட்ட நிலையில் உள்ளது. மாற்றங்களை வைத்திருக்க புதிய கிளையை உருவாக்கவும்.</x:String>
  <x:String x:Key="Text.GitError.PushRejected" xml:space="preserve">தொலைநிலையில் புதிய மாற்றங்கள் இருப்பதால் தள்ளல் நிராகரிக்கப்பட்டது. முதலில் இழுக்கவும் (அல்லது பெற்று இணைக்கவும்), பின்னர் மீண்டும் தள்ளவும்.</x:String>
  <x:String x:Key="Text.GitError.UncommittedChanges" xml:space="preserve">உறுதிசெய்யப்படாத மாற்றங்கள் உள்ளன. தொடர்வதற்கு முன் உறுதிசெய்யவும் அல்லது ஒதுக்கி வைக்கவும்.</x:String>
  <x:String x:Key="Text.GitError.AuthFailed" xml:space="preserve">அங்கீகாரம் தோல்வியடைந்தது. சான்றுகள், SSH விசை அல்லது தனிப்பட்ட அணுகல் டோக்கனை சரிபார்க்கவும்.</x:String>
  <x:String x:Key="Text.GitError.KeyPermissionTooOpen" xml:space="preserve">SSH தனிப்பட்ட விசை கோப்பின் அனுமதிகள் மிகவும் திறந்தவை. விசை கோப்பு உரிமையாளருக்கு மட்டுமே அணுகக்கூடியதாக இருக்க வேண்டும் (chmod 600).</x:String>
  <x:String x:Key="Text.GitError.KeyPermissionTooOpen.Fix" xml:space="preserve">அனுமதிகளை சரிசெய் (chmod 600)</x:String>
  <x:String x:Key="Text.GitError.RemoteNotFound" xml:space="preserve">தொலைநிலை களஞ்சியம் கண்டறியப்படவில்லை. URL மற்றும் பிணைய இணைப்பை சரிபார்க்கவும்.</x:String>
  <x:String x:Key="Text.GitError.AlreadyExists" xml:space="preserve">அந்தப் பெயரில் ஒரு கிளை அல்லது குறிச்சொல் ஏற்கனவே உள்ளது. வேறு பெயரைத் தேர்ந்தெடுக்கவும்.</x:String>
  <x:String x:Key="Text.GitError.UntrackedOverwritten" xml:space="preserve">கண்காணிக்கப்படாத கோப்புகள் மேலெழுதப்படும். அவற்றை நகர்த்தவும் அல்லது நீக்கவும், அல்லது stash பயன்படுத்தவும்.</x:String>
  <x:String x:Key="Text.GitError.NetworkError" xml:space="preserve">பிணைய இணைப்பு தோல்வியடைந்தது. இணைய இணைப்பு மற்றும் proxy அமைப்புகளை சரிபார்க்கவும்.</x:String>
  <x:String x:Key="Text.GitError.RebaseInProgress" xml:space="preserve">Rebase நடைபெற்றுக்கொண்டிருக்கிறது. முதலில் தற்போதைய rebase-ஐ தொடரவும், தவிர்க்கவும் அல்லது நிறுத்தவும்.</x:String>
  <x:String x:Key="Text.GitError.NothingToCommit" xml:space="preserve">உறுதிசெய்ய நிலைப்படுத்தப்பட்ட மாற்றங்கள் இல்லை. முதலில் கோப்புகளை நிலைப்படுத்தவும்.</x:String>
  <x:String x:Key="Text.GitError.SubmoduleError" xml:space="preserve">துணைத்தொகுதி சிக்கல் கண்டறியப்பட்டது. 'git submodule update --init --recursive' இயக்கி பாருங்கள்.</x:String>
  <x:String x:Key="Text.GitError.LfsError" xml:space="preserve">Git LFS நிறுவப்படவில்லை அல்லது கட்டமைக்கப்படவில்லை. Git LFS நிறுவி 'git lfs install' இயக்கவும்.</x:String>
  <x:String x:Key="Text.GitError.FileTooLarge" xml:space="preserve">கோப்பு அளவு வரம்பை மீறுகிறது. பெரிய கோப்புகளைக் கண்காணிக்க Git LFS பயன்படுத்தவும்.</x:String>
  <x:String x:Key="Text.GitError.CherryPickConflict" xml:space="preserve">Cherry-pick முரண்பாடுகளை ஏற்படுத்தியது. முரண்பாடுகளைத் தீர்த்து, 'git cherry-pick --continue' அல்லது '--abort' இயக்கவும்.</x:String>
  <x:String x:Key="Text.GitError.MergeNotFinished" xml:space="preserve">முந்தைய இணைப்பு முடிவடையவில்லை. 'git merge --abort' இயக்கி ரத்து செய்யவும், அல்லது தீர்வு காணி உறுதிசெய்யவும்.</x:String>
  <x:String x:Key="Text.GitError.NoUpstream" xml:space="preserve">மேல்நிலை கிளை அமைக்கப்படவில்லை. கண்காணிப்பை அமைக்க 'git push -u origin &lt;கிளை&gt;' பயன்படுத்தவும்.</x:String>
  <x:String x:Key="Text.GitError.ShallowClone" xml:space="preserve">இது வரையறுக்கப்பட்ட வரலாற்றுடன் கூடிய மேலோட்ட நகல். முழு வரலாற்றைப் பெற 'git fetch --unshallow' இயக்கவும்.</x:String>
  <x:String x:Key="Text.GitError.DiskFull" xml:space="preserve">வட்டு இடம் போதுமானதாக இல்லை. இடத்தை காலி செய்து மீண்டும் முயற்சிக்கவும்.</x:String>
  <x:String x:Key="Text.GitError.PermissionDenied" xml:space="preserve">கோப்பு அமைப்பு அனுமதி மறுக்கப்பட்டது. கோப்பு/அடைவு அனுமதிகளை சரிபார்க்கவும் அல்லது பொருத்தமான உரிமைகளுடன் இயக்கவும்.</x:String>
  <x:String x:Key="Text.GitError.InvalidRef" xml:space="preserve">தவறான குறிப்பு பெயர் அல்லது திருத்தம். கிளை, குறிச்சொல் அல்லது உறுதிப்படுத்தல் பெயரில் எழுத்துப் பிழைகளை சரிபார்க்கவும்.</x:String>
  <x:String x:Key="Text.GitError.RemoteRefNotFound" xml:space="preserve">தொலைநிலை கிளை அல்லது குறிப்பு கண்டறியப்படவில்லை. நீக்கப்பட்டிருக்கலாம். 'git fetch --prune' இயக்கி புதுப்பிக்கவும்.</x:String>
  <x:String x:Key="Text.GitError.CorruptObject" xml:space="preserve">களஞ்சியத்தில் சிதைந்த அல்லது காணாமல் போன பொருட்கள் உள்ளன. 'git fsck' பயன்படுத்தி கண்டறியவும், தேவைப்பட்டால் மீண்டும் நகலெடுக்கவும்.</x:String>
  <x:String x:Key="Text.GitError.NotARepo" xml:space="preserve">இந்த அடைவு git களஞ்சியம் அல்ல. 'git init' இயக்கி உருவாக்கவும், அல்லது பாதையை சரிபார்க்கவும்.</x:String>
  <x:String x:Key="Text.GitError.StashError" xml:space="preserve">stash பதிவுகள் கண்டறியப்படவில்லை. பயன்படுத்த சேமிக்கப்பட்ட மாற்றங்கள் இல்லை.</x:String>
  <x:String x:Key="Text.GitError.FilterError" xml:space="preserve">clean/smudge வடிகட்டி தோல்வியடைந்தது. .gitattributes மற்றும் வடிகட்டி அமைப்பை சரிபார்க்கவும்.</x:String>
  <x:String x:Key="Text.GitError.HookFailed" xml:space="preserve">git hook செயலை நிராகரித்தது. hook ஸ்கிரிப்ட்டை சரிபார்க்கவும் அல்லது '--no-verify' பயன்படுத்தி புறக்கணிக்கவும் (எச்சரிக்கையுடன்).</x:String>
  <x:String x:Key="Text.GitError.PatchFailed" xml:space="preserve">இணைப்பை சரியாக பயன்படுத்த இயலவில்லை. இலக்கு கோப்புகள் மாறியிருக்கலாம். கைமுறையாக தீர்க்க முயற்சிக்கவும்.</x:String>
  <x:String x:Key="Text.GitError.HostKeyChanged" xml:space="preserve">தொலைநிலை ஹோஸ்டின் SSH விசை கடைசி இணைப்பிலிருந்து மாறியுள்ளது. சர்வர் மறுநிறுவப்பட்டிருக்கலாம் அல்லது அதன் விசை புதுப்பிக்கப்பட்டிருக்கலாம். ~/.ssh/known_hosts இலிருந்து பழைய விசையை நீக்கிவிட்டு மீண்டும் முயற்சிக்கவும்.</x:String>
  <x:String x:Key="Text.GitError.HostKeyVerifyFailed" xml:space="preserve">SSH ஹோஸ்ட் விசை சரிபார்ப்பு தோல்வியடைந்தது. ஹோஸ்ட் உங்கள் ~/.ssh/known_hosts கோப்பில் பதிவு செய்யப்படாமல் இருக்கலாம். ஹோஸ்ட் விசையைச் சேர்க்க முதலில் டெர்மினல் வழியாக இணைக்கவும், அல்லது SSH அமைப்புகளை சரிபார்க்கவும்.</x:String>
  <x:String x:Key="Text.GitError.WorktreeError" xml:space="preserve">Worktree முரண்பாடு: கிளை வேறு இடத்தில் ஏற்கனவே சரிபார்க்கப்பட்டிருக்கலாம். 'git worktree list' பயன்படுத்தி சரிபார்க்கவும்.</x:String>
</ResourceDictionary>
