  <x:String x:Key="Text.InteractiveRebase.On" xml:space="preserve">மேல்:</x:String>
  <x:String x:Key="Text.InteractiveRebase.ReorderTip" xml:space="preserve">Commit-களை மறுவரிசைப்படுத்த இழுத்து விடவும்</x:String>
