  <x:String x:Key="Text.MergeConflictEditor.UnsavedChanges" xml:space="preserve">சேமிக்கப்படாத மாற்றங்களை நிராகரிக்கவா?</x:String>
  <x:String x:Key="Text.MergeConflictEditor.UseMine" xml:space="preserve">என்னுடையதைப் பயன்படுத்து</x:String>
  <x:String x:Key="Text.MergeConflictEditor.UseTheirs" xml:space="preserve">அவர்களுடையதைப் பயன்படுத்து</x:String>
