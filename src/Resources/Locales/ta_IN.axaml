  <x:String x:Key="Text.MoveRepositoryNode.Target" xml:space="preserve">இதற்கான பெற்றோர் முனையைத் தேர்ந்தெடு</x:String>
  <x:String x:Key="Text.Name" xml:space="preserve">பெயர்:</x:String>
