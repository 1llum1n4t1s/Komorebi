  <x:String x:Key="Text.Submodule.RelativePath.Placeholder" xml:space="preserve">இந்த தொகுதியை சேமிப்பதற்கான தொடர்புடைய கோப்புறை.</x:String>
  <x:String x:Key="Text.Submodule.Remove" xml:space="preserve">துணை தொகுதியை நீக்கு</x:String>
  <x:String x:Key="Text.Submodule.SetBranch" xml:space="preserve">கிளையை அமை</x:String>
  <x:String x:Key="Text.Submodule.SetURL" xml:space="preserve">URL-ஐ மாற்று</x:String>
  <x:String x:Key="Text.Submodule.Status" xml:space="preserve">STATUS</x:String>
  <x:String x:Key="Text.Submodule.Status.Modified" xml:space="preserve">மாற்றப்பட்டது</x:String>
  <x:String x:Key="Text.Submodule.Status.NotInited" xml:space="preserve">துவக்கப்படவில்லை</x:String>
  <x:String x:Key="Text.Submodule.Status.RevisionChanged" xml:space="preserve">திருத்தம் மாற்றப்பட்டது</x:String>
  <x:String x:Key="Text.Submodule.Status.Unmerged" xml:space="preserve">merge செய்யப்படவில்லை</x:String>
  <x:String x:Key="Text.Submodule.Update" xml:space="preserve">புதுப்பி</x:String>
  <x:String x:Key="Text.Submodule.URL" xml:space="preserve">URL</x:String>
  <x:String x:Key="Text.Sure" xml:space="preserve">சரி</x:String>
  <x:String x:Key="Text.Tag.Tagger" xml:space="preserve">TAGGER</x:String>
  <x:String x:Key="Text.Tag.Time" xml:space="preserve">TIME</x:String>
  <x:String x:Key="Text.TagCM.CompareTwo" xml:space="preserve">2 குறிச்சொற்களை ஒப்பிடு</x:String>
  <x:String x:Key="Text.TagCM.CompareWith" xml:space="preserve">இதனுடன் ஒப்பிடு...</x:String>
  <x:String x:Key="Text.TagCM.CompareWithHead" xml:space="preserve">HEAD உடன் ஒப்பிடு</x:String>
  <x:String x:Key="Text.TagCM.Copy.Message" xml:space="preserve">செய்தி</x:String>
  <x:String x:Key="Text.TagCM.Copy.Name" xml:space="preserve">பெயர்</x:String>
  <x:String x:Key="Text.TagCM.Copy.Tagger" xml:space="preserve">Tagger</x:String>
  <x:String x:Key="Text.TagCM.CopyName" xml:space="preserve">குறிச்சொல் பெயரை நகலெடு</x:String>
  <x:String x:Key="Text.TagCM.CustomAction" xml:space="preserve">தனிப்பயன் செயல்</x:String>
  <x:String x:Key="Text.TagCM.Delete" xml:space="preserve">நீக்கு ${0}$...</x:String>
  <x:String x:Key="Text.TagCM.DeleteMultiple" xml:space="preserve">தேர்ந்தெடுத்த {0} குறிச்சொற்களை நீக்கு...</x:String>
