  <x:String x:Key="Text.MergeConflictEditor.NextConflict" xml:space="preserve">அடுத்த முரண்பாடு</x:String>
  <x:String x:Key="Text.MergeConflictEditor.PrevConflict" xml:space="preserve">முந்தைய முரண்பாடு</x:String>
  <x:String x:Key="Text.MergeConflictEditor.Result" xml:space="preserve">முடிவு</x:String>
