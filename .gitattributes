*          text=auto
*.md       text
*.png      binary
*.ico      binary
*.sh       text eol=lf
*.spec     text eol=lf
control    text eol=lf
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf
*.json     text

# .axaml は xml2js の round-trip で Windows の CRLF が &#xD; エンティティとして
# 累積する問題（localization-check.js 実行時に増殖）を防ぐため LF で固定する。
*.axaml    text eol=lf

.gitattributes export-ignore
.gitignore     export-ignore
